@using PawdoptApp.Models
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Dashboard";
    var users    = ViewData["Users"]    as List<ApplicationUser> ?? new();
    var listings = ViewData["Listings"] as List<PetListing>      ?? new();
    var adopters = users.Count(u => u.UserType == "Adopter");
    var rehomers = users.Count(u => u.UserType == "Rehomer");
    var pending  = listings.Count(l => l.Status == "Pending");
    var approved = listings.Count(l => l.Status == "Approved");
}

@if (TempData["AdminMsg"] != null)
{
    <div class="adm-toast">@TempData["AdminMsg"]</div>
}

<!-- Page header -->
<div class="adm-page-header">
    <h1 class="adm-page-title">Overview</h1>
    <p class="adm-page-sub">Platform activity at a glance</p>
</div>

<!-- Stats -->
<div class="adm-stats">
    <div class="adm-stat">
        <div class="adm-stat-icon" style="background:#f0f9ff;">👥</div>
        <div class="adm-stat-num">@users.Count</div>
        <div class="adm-stat-lbl">Total Users</div>
    </div>
    <div class="adm-stat">
        <div class="adm-stat-icon" style="background:#f0fdfa;">🏠</div>
        <div class="adm-stat-num">@adopters</div>
        <div class="adm-stat-lbl">Adopters</div>
    </div>
    <div class="adm-stat">
        <div class="adm-stat-icon" style="background:#fffbeb;">🐾</div>
        <div class="adm-stat-num">@rehomers</div>
        <div class="adm-stat-lbl">Rehomers</div>
    </div>
    <div class="adm-stat">
        <div class="adm-stat-icon" style="background:#f0fdf4;">✅</div>
        <div class="adm-stat-num">@approved</div>
        <div class="adm-stat-lbl">Active Listings</div>
    </div>
    <div class="adm-stat @(pending > 0 ? "warn" : "")">
        <div class="adm-stat-icon" style="background:#fffbeb;">⏳</div>
        <div class="adm-stat-num">@pending</div>
        <div class="adm-stat-lbl">Pending Review</div>
    </div>
</div>

<!-- Listings -->
<div class="adm-card" id="adm-listings">
    <div class="adm-card-header">
        <h2 class="adm-card-title">Pet Listings</h2>
        <span class="adm-card-count">@listings.Count total</span>
    </div>
    @if (!listings.Any())
    {
        <div class="adm-empty">No listings yet.</div>
    }
    else
    {
        <div class="adm-table-wrap">
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>Pet</th>
                        <th>Rehomer</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var listing in listings)
                    {
                        <tr>
                            <td>
                                <div class="adm-user-cell">
                                    <div class="adm-avatar" style="background:#f0f9ff;color:#0e7490;font-size:1rem;">
                                        @(listing.Species == "cat" ? "🐱" : listing.Species == "rabbit" ? "🐰" : "🐶")
                                    </div>
                                    <div>
                                        <div class="adm-cell-main">@listing.Name</div>
                                        <div class="adm-cell-sub">@listing.Breed · @listing.Age</div>
                                    </div>
                                </div>
                            </td>
                            <td style="color:#475569;font-size:0.85rem;">@(listing.Rehomer?.DisplayName ?? "—")</td>
                            <td><span class="adm-badge @listing.Status.ToLower()">@listing.Status</span></td>
                            <td style="color:#94a3b8;font-size:0.82rem;">@(listing.PublishedAt?.ToString("MMM d, yyyy") ?? listing.CreatedAt.ToString("MMM d, yyyy"))</td>
                            <td>
                                @if (listing.Status == "Pending")
                                {
                                    <div class="adm-action-row">
                                        <form method="post" asp-controller="Admin" asp-action="ApproveListing" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@listing.Id" />
                                            <button type="submit" class="adm-btn approve">Approve</button>
                                        </form>
                                        <button type="button" class="adm-btn reject" onclick="showReject(@listing.Id)">Reject</button>
                                    </div>
                                }
                                else if (listing.Status == "Approved")
                                {
                                    <span style="font-size:0.78rem;color:#94a3b8;">Approved @listing.ApprovedAt?.ToString("MMM d")</span>
                                }
                                else if (listing.Status == "Rejected")
                                {
                                    <span style="font-size:0.78rem;color:#94a3b8;">Rejected</span>
                                }
                                else
                                {
                                    <span style="font-size:0.78rem;color:#94a3b8;">Draft</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

<!-- Users -->
<div class="adm-card" id="adm-users">
    <div class="adm-card-header">
        <h2 class="adm-card-title">Registered Users</h2>
        <span class="adm-card-count">@users.Count total</span>
    </div>
    <div class="adm-table-wrap">
        <table class="adm-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>City</th>
                    <th>Joined</th>
                    <th>Status</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in users)
                {
                    var isLocked = user.LockoutEnd.HasValue && user.LockoutEnd > DateTimeOffset.UtcNow;
                    var isSelf   = user.Id == ViewData["CurrentUserId"]?.ToString();
                    <tr>
                        <td>
                            <div class="adm-user-cell">
                                <div class="adm-avatar">@(user.DisplayName.Length > 0 ? user.DisplayName[0].ToString().ToUpper() : "?")</div>
                                <div class="adm-cell-main">@user.DisplayName</div>
                            </div>
                        </td>
                        <td style="color:#475569;font-size:0.83rem;">@user.Email</td>
                        <td>
                            @if (isSelf)
                            {
                                <span class="adm-badge @user.UserType.ToLower()">@user.UserType</span>
                            }
                            else
                            {
                                <form method="post" asp-controller="Admin" asp-action="UpdateUserRole" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <select name="role" class="adm-role-select" onchange="this.form.submit()">
                                        @foreach (var r in new[] { "Adopter", "Rehomer", "Admin" })
                                        {
                                            <option value="@r" selected="@(user.UserType == r)">@r</option>
                                        }
                                    </select>
                                </form>
                            }
                        </td>
                        <td style="color:#94a3b8;font-size:0.82rem;">@(string.IsNullOrEmpty(user.City) ? "—" : $"{user.City}, {user.Province}")</td>
                        <td style="color:#94a3b8;font-size:0.82rem;">@user.CreatedAt.ToString("MMM d, yyyy")</td>
                        <td>
                            @if (isLocked)
                            {
                                <span class="adm-badge rejected">Deactivated</span>
                            }
                            else
                            {
                                <span class="adm-badge approved">Active</span>
                            }
                        </td>
                        <td>
                            @if (!isSelf)
                            {
                                <form method="post" asp-controller="Admin" asp-action="ToggleUserActive" style="display:inline">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="userId" value="@user.Id" />
                                    <button type="submit" class="adm-btn @(isLocked ? "approve" : "reject")">@(isLocked ? "Reactivate" : "Deactivate")</button>
                                </form>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

<!-- Reject modal -->
<div class="adm-modal-backdrop" id="rejectBackdrop" style="display:none">
    <div class="adm-modal">
        <h3 class="adm-modal-title">Reject listing</h3>
        <form method="post" asp-controller="Admin" asp-action="RejectListing" id="rejectForm">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" id="rejectListingId" />
            <label class="adm-modal-label">Reason (shown to rehomer)</label>
            <textarea class="adm-modal-textarea" name="reason" placeholder="e.g. Missing vaccination info, photos unclear…" rows="3"></textarea>
            <div class="adm-modal-btns">
                <button type="button" class="adm-btn" onclick="hideReject()">Cancel</button>
                <button type="submit" class="adm-btn reject">Reject Listing</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
<script>
function showReject(id) {
    document.getElementById('rejectListingId').value = id;
    document.getElementById('rejectBackdrop').style.display = 'flex';
}
function hideReject() {
    document.getElementById('rejectBackdrop').style.display = 'none';
}
document.getElementById('rejectBackdrop').addEventListener('click', function (e) {
    if (e.target === this) hideReject();
});
</script>
}
