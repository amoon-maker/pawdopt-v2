<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Pawdopt</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/PawdoptApp.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg pawdopt-navbar">
            <div class="container pawdopt-nav-container">

                <a class="navbar-brand pawdopt-brand" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/images/logo.png" alt="Pawdopt" class="brand-logo" />
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarContent" aria-controls="navbarContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarContent">
                    <ul class="navbar-nav mx-auto gap-1">
                        <li class="nav-item">
                            <a class="nav-link pawdopt-nav-link active" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link pawdopt-nav-link" href="#">Adopt</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link pawdopt-nav-link" href="#">Rehome</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link pawdopt-nav-link" href="#">Care Guide</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link pawdopt-nav-link" href="#">About Us</a>
                        </li>
                    </ul>

                    <div class="navbar-right-actions d-flex align-items-center gap-3">
                        <span class="lang-toggle">EN / FR</span>
                        <button class="nav-icon-btn" title="Toggle dark mode" aria-label="Dark mode">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
                            </svg>
                        </button>
                        <button class="nav-icon-btn bell-btn" title="Notifications" aria-label="Notifications">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="#f0a500" stroke="#f0a500" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
                                <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
                            </svg>
                        </button>
                        <a href="#" class="btn btn-pawdopt-cta">Login / Register</a>
                    </div>
                </div>

            </div>
        </nav>
    </header>

    <main role="main">
        @RenderBody()
    </main>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
