@model PawdoptApp.ViewComponents.NotificationBellModel
@{
    var hasUnread = Model.UnreadCount > 0;
}

<div class="nav-notif-wrap" id="notifWrap">
    <button class="nav-icon-btn notif-btn" id="notifBtn"
            title="Notifications" aria-label="Notifications" aria-expanded="false">
        <svg width="20" height="20" viewBox="0 0 24 24"
             fill="@(hasUnread ? "#f0a500" : "none")"
             stroke="@(hasUnread ? "#f0a500" : "currentColor")"
             stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"/>
            <path d="M13.73 21a2 2 0 0 1-3.46 0"/>
        </svg>
        @if (hasUnread)
        {
            <span class="notif-badge">@(Model.UnreadCount > 9 ? "9+" : Model.UnreadCount.ToString())</span>
        }
    </button>

    <div class="notif-dropdown" id="notifDropdown">
        <div class="notif-dropdown-header">
            <span class="notif-dropdown-title">Notifications</span>
            @if (hasUnread)
            {
                <form asp-controller="Notifications" asp-action="MarkAllRead" method="post" class="notif-mark-all-form" style="margin:0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="notif-mark-all">Mark all read</button>
                </form>
            }
        </div>

        @if (Model.Notifications.Count == 0)
        {
            <div class="notif-empty">
                <span>🐾</span>
                <p>No notifications yet</p>
            </div>
        }
        else
        {
            <div class="notif-list">
                @foreach (var n in Model.Notifications)
                {
                    <a class="notif-item @(n.IsRead ? "" : "unread")"
                       href="@(n.LinkUrl ?? "#")"
                       data-notif-id="@n.Id">
                        <span class="notif-icon">@GetIcon(n.Type)</span>
                        <div class="notif-content">
                            <div class="notif-title">@n.Title</div>
                            @if (!string.IsNullOrEmpty(n.Body))
                            {
                                <div class="notif-body">@n.Body</div>
                            }
                            <div class="notif-time">@TimeAgo(n.CreatedAt)</div>
                        </div>
                        @if (!n.IsRead)
                        {
                            <span class="notif-dot"></span>
                        }
                    </a>
                }
            </div>
        }
    </div>
</div>

@functions {
    static string GetIcon(string type) => type switch
    {
        "new_listing"       => "📋",
        "listing_submitted" => "📤",
        "listing_approved"  => "✅",
        "listing_rejected"  => "❌",
        "new_application"   => "📝",
        "app_submitted"     => "📨",
        "app_status_change" => "🔔",
        "new_message"       => "💬",
        _                   => "🐾"
    };

    static string TimeAgo(DateTime dt)
    {
        var diff = DateTime.UtcNow - dt;
        if (diff.TotalMinutes < 1) return "just now";
        if (diff.TotalHours   < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays    < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays    < 7) return $"{(int)diff.TotalDays}d ago";
        return dt.ToString("MMM d");
    }
}
