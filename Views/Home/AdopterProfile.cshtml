@using PawdoptApp.Models
@{
    ViewData["Title"] = "My Profile";
    var displayName  = ViewData["UserDisplayName"] as string ?? "User";
    var userEmail    = ViewData["UserEmail"]       as string ?? "";
    var userType     = ViewData["UserType"]        as string ?? "Adopter";
    var userCity     = ViewData["UserCity"]        as string ?? "";
    var userProvince = ViewData["UserProvince"]    as string ?? "QC";
    var userPhone    = ViewData["UserPhone"]       as string ?? "";
    var memberSince  = ViewData["MemberSince"]     as string ?? "2026";
    var initial      = ViewData["UserInitial"]     as string ?? "U";
    var activeTab    = ViewData["ActiveTab"]       as string ?? "";
    var location     = string.IsNullOrEmpty(userCity) ? userProvince : $"{userCity}, {userProvince}";
    var applications     = ViewData["Applications"]         as List<AdoptionApplication> ?? new();
    var myListings       = ViewData["Listings"]             as List<PetListing>          ?? new();
    var incomingApps     = ViewData["IncomingApplications"] as List<AdoptionApplication> ?? new();
    var isRehomer        = userType == "Rehomer" || userType == "Admin";
    var completion       = ViewData["ProfileCompletion"] as int? ?? 0;
}

<div class="ap-page-wrap">
    <div class="adopt-pg-container">

        <!-- Profile header card -->
        <div class="ap-header-card">
            <div class="ap-header-top">
                <div class="ap-avatar">@initial</div>
                <div class="ap-header-info">
                    <div class="ap-name">@displayName</div>
                    <div class="ap-meta">
                        <span class="ap-meta-item">📍 @location</span>
                        <span class="ap-meta-item">🗓 Member since @memberSince</span>
                        <span class="ap-meta-item">✉️ @userEmail</span>
                    </div>
                    <div class="ap-role-badge">@userType</div>
                </div>
                <button class="ap-edit-btn" id="apEditBtn">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                         stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                    Edit Profile
                </button>
            </div>
            <div class="ap-completion-wrap">
                <div class="ap-completion-label">
                    <span data-i18n="ap-completion">Profile completion</span>
                    <span class="ap-completion-pct">@completion%</span>
                </div>
                <div class="ap-completion-bar">
                    <div class="ap-completion-fill" style="width:@(completion)%"></div>
                </div>
                <div class="ap-completion-hint">
                    @if (completion >= 100)
                    {
                        <span data-i18n="ap-completion-complete">Your profile is complete!</span>
                    }
                    else
                    {
                        <span data-i18n="ap-completion-incomplete">Add your city and phone number, and use the platform, to reach 100%</span>
                    }
                </div>
            </div>
        </div>

        <!-- Tabs nav -->
        <div class="ap-tabs-nav" role="tablist">
            <button class="ap-tab active" data-tab="overview" role="tab" aria-selected="true" data-i18n="ap-tab-overview">Overview</button>
            <button class="ap-tab" data-tab="applications" role="tab" aria-selected="false">
                @(isRehomer ? "Applications Received" : "My Applications")
            </button>
            @if (isRehomer)
            {
                <button class="ap-tab" data-tab="listings" role="tab" aria-selected="false" data-i18n="ap-tab-listings">My Listings</button>
            }
            <button class="ap-tab" data-tab="saved" role="tab" aria-selected="false" data-i18n="ap-tab-saved">Saved Pets</button>
            <button class="ap-tab" data-tab="settings" role="tab" aria-selected="false" data-i18n="ap-tab-settings">Settings</button>
        </div>

        <!-- ── Tab: Overview ──────────────────────────── -->
        <div class="ap-panel active" id="tab-overview" role="tabpanel">

            <!-- Stats row -->
            <div class="ap-stats-row">
                <div class="ap-stat-card">
                    <span class="ap-stat-num">@applications.Count</span>
                    <span class="ap-stat-lbl" data-i18n="ap-stat-apps">Applications sent</span>
                </div>
                <div class="ap-stat-card">
                    <span class="ap-stat-num" id="apSavedCount">—</span>
                    <span class="ap-stat-lbl" data-i18n="ap-stat-saved">Pets saved</span>
                </div>
                <div class="ap-stat-card">
                    <span class="ap-stat-num">@completion%</span>
                    <span class="ap-stat-lbl" data-i18n="ap-stat-profile">Profile complete</span>
                </div>
            </div>

            <!-- Recent activity -->
            <div class="ap-section-title" data-i18n="ap-recent">Recent activity</div>
            <div class="ap-activity-list">
                @if (!applications.Any() && !myListings.Any())
                {
                    <div class="ap-activity-empty">No activity yet. <a href="/Home/Adopt">Browse pets</a> to get started.</div>
                }
                @foreach (var app in applications.Take(3))
                {
                    var diff = (DateTime.UtcNow - app.SubmittedAt);
                    var timeStr = diff.TotalDays >= 7 ? ((int)(diff.TotalDays / 7)) + " weeks ago"
                                : diff.TotalDays >= 1 ? ((int)diff.TotalDays) + " days ago"
                                : diff.TotalHours >= 1 ? ((int)diff.TotalHours) + "h ago" : "just now";
                    <div class="ap-activity-item">
                        <span class="ap-activity-icon">📝</span>
                        <div>
                            <div class="ap-activity-text">Applied to adopt <strong>@app.PetListing?.Name</strong></div>
                            <div class="ap-activity-sub">Status: @app.Status</div>
                        </div>
                        <span class="ap-activity-time">@timeStr</span>
                    </div>
                }
                @foreach (var listing in myListings.Take(2))
                {
                    <div class="ap-activity-item">
                        <span class="ap-activity-icon">🏠</span>
                        <div>
                            <div class="ap-activity-text">Listed <strong>@listing.Name</strong> for rehoming</div>
                            <div class="ap-activity-sub">@listing.Breed · Status: @listing.Status</div>
                        </div>
                        <span class="ap-activity-time">@listing.CreatedAt.ToString("MMM d")</span>
                    </div>
                }
            </div>
        </div>

        <!-- ── Tab: Applications ──────────────────────── -->
        <div class="ap-panel" id="tab-applications" role="tabpanel">
            @if (isRehomer)
            {
                <div class="ap-section-title">Applications Received</div>
                <div class="ap-app-list">
                    @if (!incomingApps.Any())
                    {
                        <div class="ap-app-empty">
                            <p>No applications received yet.</p>
                            <a href="/Rehome/List" class="btn btn-pawdopt-cta" style="margin-top:12px">View my listings</a>
                        </div>
                    }
                    @foreach (var app in incomingApps)
                    {
                        var statusClass = app.Status switch {
                            "Pending"     => "pending",
                            "UnderReview" => "reviewing",
                            "Approved"    => "approved",
                            "Rejected"    => "not-selected",
                            "Withdrawn"   => "not-selected",
                            _             => "pending"
                        };
                        var statusLabel = app.Status == "UnderReview" ? "Under Review" : app.Status;
                        <div class="ap-app-card">
                            <div class="ap-app-emoji">🐾</div>
                            <div class="ap-app-info">
                                <div class="ap-app-name">@app.PetListing?.Name</div>
                                <div class="ap-app-meta" style="font-size:0.8rem;color:var(--text-secondary)">@(app.PetListing?.Breed) &middot; @(app.PetListing?.Age)</div>
                                <div class="ap-app-date">Received: @app.SubmittedAt.ToString("MMMM d, yyyy")</div>
                            </div>
                            <span class="ap-app-status @statusClass">@statusLabel</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="ap-section-title" data-i18n="ap-my-apps">My adoption applications</div>
                <div class="ap-app-list">
                    @if (!applications.Any())
                    {
                        <div class="ap-app-empty">
                            <p>No applications yet.</p>
                            <a href="/Home/Adopt" class="btn btn-pawdopt-cta" style="margin-top:12px">Find a pet</a>
                        </div>
                    }
                    @foreach (var app in applications)
                    {
                        var statusClass = app.Status switch {
                            "Pending"     => "pending",
                            "UnderReview" => "reviewing",
                            "Approved"    => "approved",
                            "Rejected"    => "not-selected",
                            "Withdrawn"   => "not-selected",
                            _             => "pending"
                        };
                        var statusLabel = app.Status == "UnderReview" ? "Under Review" : app.Status;
                        <div class="ap-app-card">
                            <div class="ap-app-emoji">🐾</div>
                            <div class="ap-app-info">
                                <div class="ap-app-name">@app.PetListing?.Name</div>
                                <div class="ap-app-date">Applied: @app.SubmittedAt.ToString("MMMM d, yyyy")</div>
                                @if (app.Status == "Pending" || app.Status == "UnderReview")
                                {
                                    <div class="ap-app-actions">
                                        <form method="post" asp-controller="Home" asp-action="WithdrawApplication" style="display:inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@app.Id" />
                                            <button type="submit" class="ap-app-btn outline"
                                                onclick="return confirm('Withdraw this application?')">Withdraw</button>
                                        </form>
                                    </div>
                                }
                            </div>
                            <span class="ap-app-status @statusClass">@statusLabel</span>
                        </div>
                    }
                </div>
            }
        </div>

        @if (isRehomer)
        {
        <!-- ── Tab: My Listings ───────────────────────── -->
        <div class="ap-panel" id="tab-listings" role="tabpanel">
            <div class="ap-section-title" data-i18n="ap-my-listings-title">My pet listings</div>
            @if (TempData["ListingMsg"] != null)
            {
                <div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:0.9rem">@TempData["ListingMsg"]</div>
            }
            @if (TempData["ListingError"] != null)
            {
                <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:0.9rem">@TempData["ListingError"]</div>
            }
            <div class="ap-app-list">
                @if (!myListings.Any())
                {
                    <div class="ap-app-empty">
                        <p data-i18n="ap-no-listings">No listings yet.</p>
                        <a href="/Rehome/NewListing" class="btn btn-pawdopt-cta" style="margin-top:12px" data-i18n="ap-list-a-pet">List a pet</a>
                    </div>
                }
                @foreach (var listing in myListings)
                {
                    var lstClass = listing.Status switch {
                        "Approved" => "approved",
                        "Pending"  => "pending",
                        "Rejected" => "not-selected",
                        _          => "reviewing"
                    };
                    <div class="ap-app-card">
                        <div class="ap-app-emoji">@(listing.Species == "cat" ? "🐱" : listing.Species == "rabbit" ? "🐰" : "🐶")</div>
                        <div class="ap-app-info">
                            <div class="ap-app-name">@listing.Name</div>
                            <div class="ap-app-breed">@listing.Breed · @(string.IsNullOrEmpty(listing.City) ? listing.Province : $"{listing.City}, {listing.Province}")</div>
                            <div class="ap-app-date">Created: @listing.CreatedAt.ToString("MMMM d, yyyy")</div>
                            @if (!string.IsNullOrEmpty(listing.RejectionReason))
                            {
                                <div class="ap-app-breed" style="color:#dc2626;margin-top:4px">@listing.RejectionReason</div>
                            }
                            <div class="ap-app-actions">
                                @if (listing.Status == "Draft")
                                {
                                    <a href="/Rehome/Confirm/@listing.Id" class="ap-app-btn" data-i18n="ap-listing-continue">Continue →</a>
                                }
                                @if (listing.Status == "Rejected")
                                {
                                    <a href="/Rehome/NewListing/@listing.Id" class="ap-app-btn" data-i18n="ap-listing-edit-resubmit">Edit &amp; resubmit →</a>
                                }
                                <form method="post" asp-controller="Rehome" asp-action="DeleteListing" asp-route-id="@listing.Id" style="display:inline" onsubmit="return confirm('Delete this listing? This cannot be undone.');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="ap-app-btn" style="color:#dc2626;border-color:#dc2626" data-i18n="ap-listing-delete">Delete</button>
                                </form>
                            </div>
                        </div>
                        <span class="ap-app-status @lstClass">@listing.Status</span>
                    </div>
                }
            </div>
        </div>
        }

        <!-- ── Tab: Saved Pets ────────────────────────── -->
        <div class="ap-panel" id="tab-saved" role="tabpanel">
            <div class="ap-section-title" data-i18n="ap-saved-pets">Saved pets</div>
            <div id="apSavedGrid" class="ap-saved-grid"></div>
            <div id="apSavedEmpty" class="adopt-empty-state" style="display:none">
                <div class="empty-paw">🤍</div>
                <h3 class="empty-title">No saved pets yet</h3>
                <p class="empty-desc">Heart a pet on the Adopt page to save it here.</p>
                <a asp-controller="Home" asp-action="Adopt" class="btn btn-pawdopt-cta">Browse pets</a>
            </div>
        </div>

        <!-- ── Tab: Settings ─────────────────────────── -->
        <div class="ap-panel" id="tab-settings" role="tabpanel">

            @if (TempData["ProfileSuccess"] != null)
            {
                <div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:0.9rem">@TempData["ProfileSuccess"]</div>
            }
            @if (TempData["ProfileError"] != null)
            {
                <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:0.9rem">@TempData["ProfileError"]</div>
            }
            @if (TempData["PasswordSuccess"] != null)
            {
                <div style="background:#dcfce7;color:#166534;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:0.9rem">@TempData["PasswordSuccess"]</div>
            }
            @if (TempData["PasswordError"] != null)
            {
                <div style="background:#fee2e2;color:#991b1b;padding:12px 16px;border-radius:8px;margin-bottom:16px;font-size:0.9rem">@TempData["PasswordError"]</div>
            }

            <!-- Personal info -->
            <div class="ap-settings-card">
                <div class="ap-settings-card-title" data-i18n="ap-settings-personal">Personal Information</div>
                <form asp-action="UpdateProfile" asp-controller="Home" method="post">
                    @Html.AntiForgeryToken()
                    <div class="ap-form-row">
                        <label class="ap-form-label">Full name</label>
                        <input type="text" class="ap-form-input" name="displayName" value="@displayName" />
                    </div>
                    <div class="ap-form-row">
                        <label class="ap-form-label">Email</label>
                        <input type="email" class="ap-form-input" value="@userEmail" readonly />
                    </div>
                    <div class="ap-form-row">
                        <label class="ap-form-label">Phone</label>
                        <input type="tel" class="ap-form-input" name="phone" value="@userPhone" placeholder="+1 (514) 000-0000" />
                    </div>
                    <div class="ap-form-row">
                        <label class="ap-form-label">City</label>
                        <input type="text" class="ap-form-input" name="city" value="@userCity" />
                    </div>
                    <div class="ap-form-row">
                        <label class="ap-form-label">Province</label>
                        <input type="text" class="ap-form-input" name="province" value="@userProvince" />
                    </div>
                    <button type="submit" class="ap-save-btn">Save Changes</button>
                </form>
            </div>

            <!-- Password -->
            <div class="ap-settings-card">
                <div class="ap-settings-card-title" data-i18n="ap-settings-password">Change Password</div>
                <form asp-action="ChangePassword" asp-controller="Home" method="post">
                    @Html.AntiForgeryToken()
                    <div class="ap-form-row">
                        <label class="ap-form-label">Current password</label>
                        <input type="password" class="ap-form-input" name="currentPassword" placeholder="••••••••" />
                    </div>
                    <div class="ap-form-row-2">
                        <div class="ap-form-row">
                            <label class="ap-form-label">New password</label>
                            <input type="password" class="ap-form-input" name="newPassword" placeholder="••••••••" />
                        </div>
                        <div class="ap-form-row">
                            <label class="ap-form-label">Confirm new password</label>
                            <input type="password" class="ap-form-input" name="confirmPassword" placeholder="••••••••" />
                        </div>
                    </div>
                    <button type="submit" class="ap-save-btn">Update Password</button>
                </form>
            </div>

            <!-- Notifications -->
            <div class="ap-settings-card">
                <div class="ap-settings-card-title" data-i18n="ap-settings-notif">Notification Preferences</div>
                <div class="ap-notif-row">
                    <div>
                        <div class="ap-notif-label">Application status updates</div>
                        <div class="ap-notif-sub">Get notified when a rehomer responds to your application</div>
                    </div>
                    <label class="ap-toggle">
                        <input type="checkbox" checked>
                        <span class="ap-toggle-slider"></span>
                    </label>
                </div>
                <div class="ap-notif-row">
                    <div>
                        <div class="ap-notif-label">New matching pets</div>
                        <div class="ap-notif-sub">Alerts when pets matching your criteria are listed</div>
                    </div>
                    <label class="ap-toggle">
                        <input type="checkbox" checked>
                        <span class="ap-toggle-slider"></span>
                    </label>
                </div>
                <div class="ap-notif-row">
                    <div>
                        <div class="ap-notif-label">Platform news &amp; tips</div>
                        <div class="ap-notif-sub">Occasional care guides and platform announcements</div>
                    </div>
                    <label class="ap-toggle">
                        <input type="checkbox">
                        <span class="ap-toggle-slider"></span>
                    </label>
                </div>
            </div>

            <!-- Danger zone -->
            <div class="ap-settings-card ap-danger-card">
                <div class="ap-settings-card-title" style="color:#dc2626">Account</div>
                <p style="font-size:0.85rem;color:var(--text-secondary);margin-bottom:14px">Deactivating your account will remove your profile and applications. This cannot be undone.</p>
                <button class="ap-danger-btn">Deactivate Account</button>
            </div>

        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    var REAL_PETS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["RealPets"]));
    var PETS = (window.PAWDOPT_PETS || []).concat(REAL_PETS);
    var SAVED_IDS = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewData["SavedPetIds"] ?? new List<int>()));

    function favToken() { return document.querySelector('input[name="__RequestVerificationToken"]')?.value || ''; }
    function toggleFav(petId) {
        return fetch('/Home/ToggleSavedPet?petId=' + petId, {
            method: 'POST',
            headers: { 'RequestVerificationToken': favToken() }
        }).then(function (r) { return r.json(); });
    }

    // ── Tab switching ────────────────────────────────────
    document.querySelectorAll('.ap-tab').forEach(function (tab) {
        tab.addEventListener('click', function () {
            document.querySelectorAll('.ap-tab').forEach(function (t) {
                t.classList.remove('active');
                t.setAttribute('aria-selected', 'false');
            });
            document.querySelectorAll('.ap-panel').forEach(function (p) { p.classList.remove('active'); });
            this.classList.add('active');
            this.setAttribute('aria-selected', 'true');
            document.getElementById('tab-' + this.dataset.tab).classList.add('active');
        });
    });

    // ── Saved pets ───────────────────────────────────────
    function renderSaved() {
        var favs = new Set(SAVED_IDS);
        document.getElementById('apSavedCount').textContent = favs.size;
        var saved = PETS.filter(function (p) { return favs.has(p.id); });
        var grid  = document.getElementById('apSavedGrid');
        var empty = document.getElementById('apSavedEmpty');

        if (saved.length === 0) {
            grid.innerHTML  = '';
            empty.style.display = '';
            return;
        }
        empty.style.display = 'none';
        grid.innerHTML = saved.map(function (p) {
            var genderTag = p.gender === 'male'
                ? '<span class="pet-tag pet-tag-male">Male</span>'
                : '<span class="pet-tag pet-tag-female">Female</span>';
            var savedPhotoHtml = p.image
                ? '<img src="' + (p.image.charAt(0) === '/' ? p.image : '/images/' + p.image) + '" alt="' + p.name + '" class="pet-card-photo">'
                : '<div class="pet-card-photo" style="background:' + (p.colors || '#e8eef5') + ';display:flex;align-items:center;justify-content:center;font-size:2.75rem">' + (p.emoji || '🐾') + '</div>';
            return '<div class="pet-card">' +
                '<div class="pet-card-img">' +
                    savedPhotoHtml +
                    (p.badge === 'new' ? '<span class="pet-badge-new">New</span>' : p.badge === 'urgent' ? '<span class="pet-badge-urgent">Urgent</span>' : '') +
                    '<button class="pet-fav-btn is-fav" data-rem-id="' + p.id + '" aria-label="Remove from saved">' +
                        '<svg width="16" height="16" viewBox="0 0 24 24" fill="#ef4444" stroke="#ef4444" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>' +
                    '</button>' +
                '</div>' +
                '<div class="pet-card-body">' +
                    '<h5 class="pet-name">' + p.name + '</h5>' +
                    '<div class="pet-tags">' + genderTag + '<span class="pet-tag">' + p.breed + '</span></div>' +
                    '<p class="pet-location"><svg width="11" height="11" viewBox="0 0 24 24" fill="#ef4444"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>' + p.city + ', ' + p.province + '</p>' +
                    '<a href="/Home/PetDetail?id=' + p.id + '" class="btn btn-more-info">More Info</a>' +
                '</div>' +
            '</div>';
        }).join('');

        grid.querySelectorAll('[data-rem-id]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                var id = parseInt(this.dataset.remId, 10);
                toggleFav(id).then(function (res) {
                    if (!res.success) return;
                    var idx = SAVED_IDS.indexOf(id);
                    if (idx !== -1) SAVED_IDS.splice(idx, 1);
                    renderSaved();
                });
            });
        });
    }

    renderSaved();

    // ── Edit profile button (scrolls to settings tab) ────
    document.getElementById('apEditBtn').addEventListener('click', function () {
        document.querySelector('.ap-tab[data-tab="settings"]').click();
    });

    // ── Activate tab from server redirect (e.g. after saving settings) ────
    var serverTab = '@activeTab';
    if (serverTab) {
        var targetBtn = document.querySelector('.ap-tab[data-tab="' + serverTab + '"]');
        if (targetBtn) targetBtn.click();
    }

})();
</script>
}
