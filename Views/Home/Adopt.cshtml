@{
    ViewData["Title"] = "Adopt a Pet";
}

<!-- ── Adopt Hero ─────────────────────────────────────── -->
<section class="adopt-hero-section">
    <div class="container">
        <div class="adopt-hero-content text-center">
            <div class="hero-badge" style="margin: 0 auto 1.5rem;">
                <span class="hero-badge-icon">🐾</span>
                <span data-i18n="adopt-hero-badge">Browse &amp; Adopt</span>
            </div>
            <h1 class="adopt-hero-title" data-i18n="adopt-hero-title">Find your forever companion</h1>
            <p class="adopt-hero-subtitle" data-i18n="adopt-hero-subtitle">
                Hundreds of loving pets are waiting for a home across Canada
            </p>

            <!-- Search bar -->
            <div class="adopt-search-wrap">
                <svg class="adopt-search-icon" width="20" height="20" viewBox="0 0 24 24" fill="none"
                     stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" class="adopt-search-input" id="searchInput"
                       placeholder="Search by name or breed…" data-i18n-placeholder="adopt-search-placeholder" />
                <button class="adopt-search-btn" id="searchBtn" data-i18n="adopt-search-btn">Search</button>
            </div>

            <!-- Quick stats -->
            <div class="adopt-hero-stats">
                <div class="adopt-stat">
                    <span class="adopt-stat-num" id="statAvailable">12</span>
                    <span class="adopt-stat-lbl" data-i18n="adopt-stat-available">Available pets</span>
                </div>
                <span class="adopt-stat-sep">·</span>
                <div class="adopt-stat">
                    <span class="adopt-stat-num">7</span>
                    <span class="adopt-stat-lbl" data-i18n="adopt-stat-dogs">Dogs</span>
                </div>
                <span class="adopt-stat-sep">·</span>
                <div class="adopt-stat">
                    <span class="adopt-stat-num">5</span>
                    <span class="adopt-stat-lbl" data-i18n="adopt-stat-cats">Cats</span>
                </div>
                <span class="adopt-stat-sep">·</span>
                <div class="adopt-stat">
                    <span class="adopt-stat-num">2,400+</span>
                    <span class="adopt-stat-lbl" data-i18n="adopt-stat-adopted">Successful adoptions</span>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- ── Sticky Filter Bar ──────────────────────────────── -->
<section class="adopt-filter-section" id="adoptFilterBar">
    <div class="container">
        <div class="adopt-filter-bar">

            <!-- Species tabs -->
            <div class="species-tabs" role="tablist" aria-label="Filter by species">
                <button class="species-tab active" data-species="all" role="tab" aria-selected="true" data-i18n="adopt-tab-all">All Pets</button>
                <button class="species-tab" data-species="dog" role="tab" aria-selected="false">
                    🐕 <span data-i18n="adopt-tab-dogs">Dogs</span>
                </button>
                <button class="species-tab" data-species="cat" role="tab" aria-selected="false">
                    🐈 <span data-i18n="adopt-tab-cats">Cats</span>
                </button>
            </div>

            <div class="filter-bar-divider" aria-hidden="true"></div>

            <!-- Filter dropdowns -->
            <div class="filter-selects">
                <select class="filter-select" id="filterSize" aria-label="Filter by size">
                    <option value="" data-i18n="adopt-filter-size">Size</option>
                    <option value="small" data-i18n="adopt-filter-size-small">Small</option>
                    <option value="medium" data-i18n="adopt-filter-size-medium">Medium</option>
                    <option value="large" data-i18n="adopt-filter-size-large">Large</option>
                </select>

                <select class="filter-select" id="filterAge" aria-label="Filter by age">
                    <option value="" data-i18n="adopt-filter-age">Age</option>
                    <option value="young" data-i18n="adopt-filter-age-young">Young (&lt; 1 yr)</option>
                    <option value="adult" data-i18n="adopt-filter-age-adult">Adult (1–5 yr)</option>
                    <option value="senior" data-i18n="adopt-filter-age-senior">Senior (5+ yr)</option>
                </select>

                <select class="filter-select" id="filterGender" aria-label="Filter by gender">
                    <option value="" data-i18n="adopt-filter-gender">Gender</option>
                    <option value="male" data-i18n="adopt-filter-gender-male">Male</option>
                    <option value="female" data-i18n="adopt-filter-gender-female">Female</option>
                </select>

                <select class="filter-select" id="filterProvince" aria-label="Filter by province">
                    <option value="" data-i18n="adopt-filter-province">Province</option>
                    <option value="QC">Quebec (QC)</option>
                    <option value="ON">Ontario (ON)</option>
                    <option value="BC">British Columbia (BC)</option>
                    <option value="AB">Alberta (AB)</option>
                    <option value="MB">Manitoba (MB)</option>
                    <option value="SK">Saskatchewan (SK)</option>
                    <option value="NS">Nova Scotia (NS)</option>
                    <option value="NB">New Brunswick (NB)</option>
                </select>

                <button class="filter-clear-btn" id="clearAllFiltersBtn" data-i18n="adopt-clear-all">Clear All</button>
            </div>
        </div>
    </div>
</section>

<!-- ── Results ────────────────────────────────────────── -->
<section class="adopt-results-section">
    <div class="container">

        <!-- Active filter chips -->
        <div class="active-filters-row" id="activeFiltersRow" style="display:none" aria-live="polite">
            <div class="active-filters-chips" id="activeFiltersChips"></div>
        </div>

        <!-- Results header -->
        <div class="results-header">
            <span class="results-count" id="resultsCount" aria-live="polite">
                <span data-i18n="adopt-results-showing">Showing</span>
                <strong id="resultsCountNum">12</strong>
                <span data-i18n="adopt-results-pets">pets</span>
            </span>
            <div class="results-sort-wrap">
                <label class="sort-label" for="sortSelect" data-i18n="adopt-sort-label">Sort by:</label>
                <select class="sort-select" id="sortSelect">
                    <option value="newest" data-i18n="adopt-sort-newest">Newest</option>
                    <option value="az" data-i18n="adopt-sort-az">Name A–Z</option>
                    <option value="za" data-i18n="adopt-sort-za">Name Z–A</option>
                    <option value="age-asc" data-i18n="adopt-sort-age-asc">Youngest first</option>
                    <option value="age-desc" data-i18n="adopt-sort-age-desc">Oldest first</option>
                </select>
            </div>
        </div>

        <!-- Pet grid (populated by JS) -->
        <div class="pets-grid" id="petsGrid" role="list" aria-label="Available pets"></div>

        <!-- Empty state -->
        <div class="adopt-empty-state" id="emptyState" style="display:none" role="status">
            <div class="empty-paw">🐾</div>
            <h3 class="empty-title" data-i18n="adopt-empty-title">No pets match your filters</h3>
            <p class="empty-desc" data-i18n="adopt-empty-desc">Try adjusting or clearing your filters to see more results.</p>
            <button class="btn btn-pawdopt-cta" id="emptyStateClearBtn" data-i18n="adopt-empty-btn">Clear All Filters</button>
        </div>

        <!-- Load more -->
        <div class="load-more-wrap" id="loadMoreWrap" style="display:none">
            <button class="btn btn-load-more" id="loadMoreBtn" data-i18n="adopt-load-more">Load more pets →</button>
        </div>

    </div>
</section>

@section Scripts {
<script>
(function () {
    // ── Pet data ──────────────────────────────────────────
    var PETS = [
        { id:1,  name:'Pitter', species:'dog', breed:'Pit Bull',          size:'large',  ageNum:3,  ageUnit:'yr', gender:'male',   province:'QC', city:'Montreal',    emoji:'🐕',     badge:'new',    colors:'linear-gradient(135deg,#fde8d8 0%,#e8d5f0 100%)' },
        { id:2,  name:'Hero',   species:'cat', breed:'DLH',               size:'small',  ageNum:2,  ageUnit:'yr', gender:'male',   province:'AB', city:'Calgary',     emoji:'🐈',     badge:'',       colors:'linear-gradient(135deg,#d8eef5 0%,#e8f0e8 100%)' },
        { id:3,  name:'Magie',  species:'dog', breed:'Shiba Inu',         size:'medium', ageNum:14, ageUnit:'mo', gender:'female', province:'ON', city:'Toronto',     emoji:'🐕‍🦺', badge:'',       colors:'linear-gradient(135deg,#d8e8f5 0%,#ddf0e8 100%)' },
        { id:4,  name:'Felix',  species:'cat', breed:'Domestic SH',       size:'small',  ageNum:5,  ageUnit:'yr', gender:'female', province:'BC', city:'Vancouver',   emoji:'🐱',     badge:'',       colors:'linear-gradient(135deg,#fff0d8 0%,#f5e8f0 100%)' },
        { id:5,  name:'Buddy',  species:'dog', breed:'Golden Retriever',  size:'large',  ageNum:4,  ageUnit:'yr', gender:'male',   province:'QC', city:'Quebec City', emoji:'🐶',     badge:'',       colors:'linear-gradient(135deg,#fdf8d8 0%,#f8ead8 100%)' },
        { id:6,  name:'Luna',   species:'cat', breed:'Maine Coon',        size:'medium', ageNum:1,  ageUnit:'yr', gender:'female', province:'QC', city:'Laval',       emoji:'🐈‍⬛', badge:'new',    colors:'linear-gradient(135deg,#ead8f8 0%,#d8e8f8 100%)' },
        { id:7,  name:'Rex',    species:'dog', breed:'German Shepherd',   size:'large',  ageNum:7,  ageUnit:'yr', gender:'male',   province:'ON', city:'Ottawa',      emoji:'🦮',     badge:'urgent', colors:'linear-gradient(135deg,#e0ecd5 0%,#f0e8d5 100%)' },
        { id:8,  name:'Mochi',  species:'dog', breed:'Pomeranian',        size:'small',  ageNum:8,  ageUnit:'mo', gender:'female', province:'BC', city:'Victoria',    emoji:'🐕',     badge:'new',    colors:'linear-gradient(135deg,#fce8f0 0%,#f8e8fc 100%)' },
        { id:9,  name:'Shadow', species:'cat', breed:'Russian Blue',      size:'small',  ageNum:3,  ageUnit:'yr', gender:'male',   province:'AB', city:'Edmonton',    emoji:'🐈',     badge:'',       colors:'linear-gradient(135deg,#d8e4fc 0%,#d8f0f4 100%)' },
        { id:10, name:'Bella',  species:'dog', breed:'Labrador',          size:'large',  ageNum:2,  ageUnit:'yr', gender:'female', province:'QC', city:'Sherbrooke',  emoji:'🐶',     badge:'new',    colors:'linear-gradient(135deg,#eaf8d8 0%,#d8f0f8 100%)' },
        { id:11, name:'Oliver', species:'cat', breed:'British Shorthair', size:'medium', ageNum:6,  ageUnit:'yr', gender:'male',   province:'MB', city:'Winnipeg',    emoji:'🐱',     badge:'urgent', colors:'linear-gradient(135deg,#e8dde8 0%,#dde8e0 100%)' },
        { id:12, name:'Nala',   species:'dog', breed:'Husky',             size:'large',  ageNum:3,  ageUnit:'yr', gender:'female', province:'SK', city:'Saskatoon',   emoji:'🐕',     badge:'new',    colors:'linear-gradient(135deg,#d8e8fc 0%,#fce8d8 100%)' }
    ];

    var PAGE_SIZE = 8;

    var state = {
        search:   '',
        species:  'all',
        size:     '',
        age:      '',
        gender:   '',
        province: '',
        sort:     'newest',
        page:     1,
        favorites: new Set(JSON.parse(localStorage.getItem('pawdopt-favs') || '[]'))
    };

    // ── Helpers ───────────────────────────────────────────
    function ageYears(p) {
        return p.ageUnit === 'mo' ? p.ageNum / 12 : p.ageNum;
    }

    function ageCategory(p) {
        var y = ageYears(p);
        if (y < 1)  return 'young';
        if (y <= 5) return 'adult';
        return 'senior';
    }

    function capFirst(s) { return s.charAt(0).toUpperCase() + s.slice(1); }

    // ── Filter & sort ─────────────────────────────────────
    function filterPets() {
        return PETS.filter(function (p) {
            if (state.species !== 'all' && p.species !== state.species) return false;
            if (state.search) {
                var q = state.search.toLowerCase();
                if (!p.name.toLowerCase().includes(q) && !p.breed.toLowerCase().includes(q)) return false;
            }
            if (state.size     && p.size     !== state.size)          return false;
            if (state.age      && ageCategory(p) !== state.age)       return false;
            if (state.gender   && p.gender   !== state.gender)        return false;
            if (state.province && p.province !== state.province)      return false;
            return true;
        });
    }

    function sortPets(list) {
        var sorted = list.slice();
        switch (state.sort) {
            case 'az':       return sorted.sort(function(a,b){ return a.name.localeCompare(b.name); });
            case 'za':       return sorted.sort(function(a,b){ return b.name.localeCompare(a.name); });
            case 'age-asc':  return sorted.sort(function(a,b){ return ageYears(a) - ageYears(b); });
            case 'age-desc': return sorted.sort(function(a,b){ return ageYears(b) - ageYears(a); });
            default:
                return sorted.sort(function(a,b){
                    var urgentA = a.badge === 'urgent' ? 2 : a.badge === 'new' ? 1 : 0;
                    var urgentB = b.badge === 'urgent' ? 2 : b.badge === 'new' ? 1 : 0;
                    return urgentB - urgentA || b.id - a.id;
                });
        }
    }

    // ── Card renderer ─────────────────────────────────────
    function renderCard(p) {
        var isFav = state.favorites.has(p.id);
        var favSvg = isFav
            ? '<svg width="18" height="18" viewBox="0 0 24 24" fill="#ef4444" stroke="#ef4444" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>'
            : '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';

        var badgeHtml = '';
        if (p.badge === 'new')    badgeHtml = '<span class="pet-badge-new">New</span>';
        if (p.badge === 'urgent') badgeHtml = '<span class="pet-badge-urgent">Urgent</span>';

        var genderTag = p.gender === 'male'
            ? '<span class="pet-tag pet-tag-male">Male</span>'
            : '<span class="pet-tag pet-tag-female">Female</span>';

        var ageLabel = p.ageNum + ' ' + p.ageUnit;

        return '<div class="pet-card adopt-pet-card" role="listitem" data-pet-id="' + p.id + '">' +
            '<div class="pet-card-img" style="background:' + p.colors + ';">' +
                badgeHtml +
                '<button class="pet-fav-btn' + (isFav ? ' is-fav' : '') + '" data-fav-id="' + p.id + '" aria-label="' + (isFav ? 'Remove from favourites' : 'Save to favourites') + '" title="' + (isFav ? 'Saved' : 'Save') + '">' +
                    favSvg +
                '</button>' +
                '<span class="pet-emoji">' + p.emoji + '</span>' +
            '</div>' +
            '<div class="pet-card-body">' +
                '<h5 class="pet-name">' + p.name + '</h5>' +
                '<p class="pet-breed-age">' + p.breed + ' &middot; ' + ageLabel + '</p>' +
                '<div class="pet-tags">' +
                    genderTag +
                    '<span class="pet-tag">' + capFirst(p.size) + '</span>' +
                '</div>' +
                '<p class="pet-location">' +
                    '<svg width="12" height="12" viewBox="0 0 24 24" fill="#ef4444"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>' +
                    p.city + ', ' + p.province +
                '</p>' +
                '<a href="#" class="btn btn-more-info adopt-more-info-btn">More Info</a>' +
            '</div>' +
        '</div>';
    }

    // ── Main render ───────────────────────────────────────
    function render() {
        var filtered = filterPets();
        var sorted   = sortPets(filtered);
        var visible  = sorted.slice(0, state.page * PAGE_SIZE);

        var grid       = document.getElementById('petsGrid');
        var empty      = document.getElementById('emptyState');
        var loadWrap   = document.getElementById('loadMoreWrap');
        var countEl    = document.getElementById('resultsCountNum');
        var statAvail  = document.getElementById('statAvailable');

        if (statAvail) statAvail.textContent = PETS.length;

        if (filtered.length === 0) {
            grid.innerHTML     = '';
            empty.style.display    = '';
            loadWrap.style.display = 'none';
        } else {
            empty.style.display = 'none';
            grid.innerHTML = visible.map(renderCard).join('');
            countEl.textContent = filtered.length;
            loadWrap.style.display = visible.length < sorted.length ? '' : 'none';

            // Fav button listeners
            grid.querySelectorAll('.pet-fav-btn').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    var id = parseInt(this.dataset.favId, 10);
                    if (state.favorites.has(id)) { state.favorites.delete(id); }
                    else { state.favorites.add(id); }
                    localStorage.setItem('pawdopt-favs', JSON.stringify(Array.from(state.favorites)));
                    render();
                });
            });
        }

        updateChips();
    }

    // ── Active filter chips ───────────────────────────────
    function updateChips() {
        var row   = document.getElementById('activeFiltersRow');
        var chips = document.getElementById('activeFiltersChips');
        var active = [];

        if (state.search)   active.push({ key:'search',   label:'"' + state.search + '"' });
        if (state.size)     active.push({ key:'size',     label:capFirst(state.size) });
        if (state.age) {
            var ageLabels = { young:'Young', adult:'Adult', senior:'Senior' };
            active.push({ key:'age', label:ageLabels[state.age] });
        }
        if (state.gender)   active.push({ key:'gender',   label:capFirst(state.gender) });
        if (state.province) active.push({ key:'province', label:state.province });

        if (active.length) {
            row.style.display = '';
            chips.innerHTML = active.map(function (f) {
                return '<button class="filter-chip" data-chip-key="' + f.key + '" aria-label="Remove ' + f.label + ' filter">' +
                    '<span>' + f.label + '</span>' +
                    '<span class="chip-remove" aria-hidden="true">&times;</span>' +
                '</button>';
            }).join('');

            chips.querySelectorAll('.filter-chip').forEach(function (chip) {
                chip.addEventListener('click', function () {
                    var key = this.dataset.chipKey;
                    if (key === 'search') { state.search = ''; var si = document.getElementById('searchInput'); if(si) si.value = ''; }
                    else { state[key] = ''; }
                    state.page = 1;
                    syncUI();
                    render();
                });
            });
        } else {
            row.style.display = 'none';
        }
    }

    // ── Sync UI controls to state ─────────────────────────
    function syncUI() {
        document.getElementById('filterSize').value     = state.size;
        document.getElementById('filterAge').value      = state.age;
        document.getElementById('filterGender').value   = state.gender;
        document.getElementById('filterProvince').value = state.province;
        document.querySelectorAll('.species-tab').forEach(function (tab) {
            var active = tab.dataset.species === state.species;
            tab.classList.toggle('active', active);
            tab.setAttribute('aria-selected', active);
        });
    }

    function clearAll() {
        state.search = ''; state.species = 'all'; state.size = ''; state.age = '';
        state.gender = ''; state.province = ''; state.page = 1;
        var si = document.getElementById('searchInput');
        if (si) si.value = '';
        syncUI();
        render();
    }

    // ── Event wiring ──────────────────────────────────────
    document.querySelectorAll('.species-tab').forEach(function (tab) {
        tab.addEventListener('click', function () {
            state.species = this.dataset.species;
            state.page = 1;
            syncUI();
            render();
        });
    });

    [['filterSize','size'],['filterAge','age'],['filterGender','gender'],['filterProvince','province']].forEach(function(pair) {
        var el = document.getElementById(pair[0]);
        if (el) el.addEventListener('change', function () {
            state[pair[1]] = this.value;
            state.page = 1;
            render();
        });
    });

    var sortEl = document.getElementById('sortSelect');
    if (sortEl) sortEl.addEventListener('change', function () {
        state.sort = this.value; render();
    });

    var clearBtn = document.getElementById('clearAllFiltersBtn');
    if (clearBtn) clearBtn.addEventListener('click', clearAll);

    var emptyClearBtn = document.getElementById('emptyStateClearBtn');
    if (emptyClearBtn) emptyClearBtn.addEventListener('click', clearAll);

    var loadMoreBtn = document.getElementById('loadMoreBtn');
    if (loadMoreBtn) loadMoreBtn.addEventListener('click', function () {
        state.page++; render();
        // Smooth scroll to newly revealed cards
        setTimeout(function() {
            var cards = document.querySelectorAll('#petsGrid .adopt-pet-card');
            var first = cards[(state.page - 1) * PAGE_SIZE];
            if (first) first.scrollIntoView({ behavior:'smooth', block:'start' });
        }, 50);
    });

    var searchInput = document.getElementById('searchInput');
    var searchBtn   = document.getElementById('searchBtn');
    if (searchInput) {
        var searchTimer;
        searchInput.addEventListener('input', function () {
            clearTimeout(searchTimer);
            var val = this.value;
            searchTimer = setTimeout(function () {
                state.search = val.trim();
                state.page = 1;
                render();
            }, 280);
        });
        searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Enter') {
                clearTimeout(searchTimer);
                state.search = this.value.trim();
                state.page = 1;
                render();
            }
        });
    }
    if (searchBtn) {
        searchBtn.addEventListener('click', function () {
            if (searchInput) {
                state.search = searchInput.value.trim();
                state.page = 1;
                render();
            }
        });
    }

    // ── Bootstrap ─────────────────────────────────────────
    render();
})();
</script>
}
