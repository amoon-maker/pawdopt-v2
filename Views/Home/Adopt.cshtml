@{
    ViewData["Title"] = "Adopt a Pet";
}

<!-- ── Breadcrumb ──────────────────────────────────────── -->
<div class="adopt-breadcrumb-bar">
    <div class="adopt-pg-container">
        <a asp-controller="Home" asp-action="Index" class="bc-link" data-i18n="nav-home">Home</a>
        <span class="bc-sep">›</span>
        <span class="bc-current" data-i18n="adopt-breadcrumb">Adopt a pet</span>
    </div>
</div>

<!-- ── Search bar ─────────────────────────────────────── -->
<div class="adopt-search-section">
    <div class="adopt-pg-container">
        <div class="adopt-top-search-wrap">
            <div class="adopt-top-search-inner">
                <svg class="adopt-top-search-icon" width="18" height="18" viewBox="0 0 24 24"
                     fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
                </svg>
                <input type="text" class="adopt-top-search-input" id="searchInput"
                       placeholder="Search by breed, name, or keyword…"
                       data-i18n-placeholder="adopt-search-placeholder" />
            </div>
            <button class="adopt-top-search-btn" id="searchBtn" data-i18n="adopt-search-btn">Search</button>
        </div>
    </div>
</div>

<!-- ── Main layout ────────────────────────────────────── -->
<div class="adopt-main-section">
    <div class="adopt-pg-container">
        <div class="adopt-split-layout">

            <!-- ── Filter sidebar ─────────────────────────── -->
            <aside class="adopt-sidebar-panel" id="adoptSidebar">

                <div class="sidebar-header-row">
                    <span class="sidebar-title" data-i18n="adopt-filters-title">Filters</span>
                    <button class="sidebar-reset-btn" id="resetFiltersBtn" data-i18n="adopt-reset-all">Reset all</button>
                </div>

                <!-- Pet type -->
                <div class="sidebar-filter-group">
                    <div class="sfg-title" data-i18n="adopt-filter-pet-type">Pet type</div>
                    <div class="sb-type-toggle">
                        <button class="sb-type-btn active" data-species="all">
                            <span class="sb-type-icon">🐾</span><span data-i18n="adopt-type-all">All</span>
                        </button>
                        <button class="sb-type-btn" data-species="dog">
                            <span class="sb-type-icon">🐕</span><span data-i18n="adopt-type-dogs">Dogs</span>
                        </button>
                        <button class="sb-type-btn" data-species="cat">
                            <span class="sb-type-icon">🐈</span><span data-i18n="adopt-type-cats">Cats</span>
                        </button>
                    </div>
                </div>

                <!-- Location -->
                <div class="sidebar-filter-group">
                    <div class="sfg-title" data-i18n="adopt-filter-location">Location</div>
                    <div class="sb-loc-display">
                        <svg width="12" height="12" viewBox="0 0 24 24" fill="#ef4444">
                            <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
                        </svg>
                        Montreal, QC
                    </div>
                    <button class="sb-loc-link" data-i18n="adopt-use-location">📡 Use current location</button>
                </div>

                <!-- Distance -->
                <div class="sidebar-filter-group">
                    <div class="sfg-title">
                        <span data-i18n="adopt-filter-distance">Distance</span> &nbsp;<span class="distance-val" id="distanceVal">25 km</span>
                    </div>
                    <input type="range" class="distance-slider" id="distanceSlider"
                           min="0" max="100" value="25" aria-label="Distance in kilometres" />
                    <div class="range-labels"><span>0 km</span><span>100 km</span></div>
                </div>

                <!-- Size -->
                <div class="sidebar-filter-group">
                    <div class="sfg-title" data-i18n="adopt-filter-size">Size</div>
                    <div class="sb-pills">
                        <button class="sb-pill" data-filter="size" data-val="" data-i18n="adopt-size-any">Any</button>
                        <button class="sb-pill" data-filter="size" data-val="small" data-i18n="tag-small">Small</button>
                        <button class="sb-pill" data-filter="size" data-val="medium" data-i18n="tag-medium">Medium</button>
                        <button class="sb-pill" data-filter="size" data-val="large" data-i18n="tag-large">Large</button>
                    </div>
                </div>

                <!-- Breed -->
                <div class="sidebar-filter-group">
                    <div class="sfg-title" data-i18n="adopt-filter-breed">Breed</div>
                    <input type="text" class="sb-text-input" id="breedInput" placeholder="Any breed…" data-i18n-placeholder="adopt-breed-placeholder" />
                </div>

                <!-- Gender -->
                <div class="sidebar-filter-group">
                    <div class="sfg-title" data-i18n="adopt-filter-gender">Gender</div>
                    <label class="sb-check-label">
                        <input type="checkbox" class="sb-check" id="checkMale"> <span data-i18n="tag-male">Male</span>
                    </label>
                    <label class="sb-check-label">
                        <input type="checkbox" class="sb-check" id="checkFemale"> <span data-i18n="tag-female">Female</span>
                    </label>
                </div>

                <!-- Age -->
                <div class="sidebar-filter-group">
                    <div class="sfg-title" data-i18n="adopt-filter-age">Age</div>
                    <div class="sb-pills">
                        <button class="sb-pill" data-filter="age" data-val="" data-i18n="adopt-age-any">Any</button>
                        <button class="sb-pill" data-filter="age" data-val="young" data-i18n="adopt-age-young">Young</button>
                        <button class="sb-pill" data-filter="age" data-val="adult" data-i18n="adopt-age-adult">Adult</button>
                        <button class="sb-pill" data-filter="age" data-val="senior" data-i18n="adopt-age-senior">Senior</button>
                    </div>
                </div>

                <!-- Health status -->
                <div class="sidebar-filter-group sidebar-filter-group--last">
                    <div class="sfg-title" data-i18n="adopt-filter-health">Health status</div>
                    <label class="sb-check-label">
                        <input type="checkbox" class="sb-check" id="checkVaccinated"> <span data-i18n="adopt-health-vaccinated">Vaccinated</span>
                    </label>
                    <label class="sb-check-label">
                        <input type="checkbox" class="sb-check" id="checkNeutered"> <span data-i18n="adopt-health-neutered">Neutered / Spayed</span>
                    </label>
                    <label class="sb-check-label">
                        <input type="checkbox" class="sb-check" id="checkMicrochipped"> <span data-i18n="adopt-health-microchipped">Microchipped</span>
                    </label>
                </div>

                <button class="sidebar-apply-btn" id="applyFiltersBtn" data-i18n="adopt-apply-filters">Apply filters</button>

            </aside>

            <!-- ── Results column ──────────────────────────── -->
            <div class="adopt-results-col">

                <!-- Results header -->
                <div class="results-header">
                    <span class="results-count" aria-live="polite">
                        <strong id="resultsCountNum">12</strong>
                        <span data-i18n="adopt-pets-found"> pets found</span>
                    </span>
                    <div class="results-sort-wrap">
                        <label class="sort-label" for="sortSelect" data-i18n="adopt-sort-label">Sort by:</label>
                        <select class="sort-select" id="sortSelect">
                            <option value="newest" data-i18n="adopt-sort-newest">Newest first</option>
                            <option value="az" data-i18n="adopt-sort-az">Name A–Z</option>
                            <option value="za" data-i18n="adopt-sort-za">Name Z–A</option>
                            <option value="age-asc" data-i18n="adopt-sort-youngest">Youngest first</option>
                            <option value="age-desc" data-i18n="adopt-sort-oldest">Oldest first</option>
                        </select>
                    </div>
                </div>

                <!-- Active filter chips -->
                <div class="active-filters-row" id="activeFiltersRow" style="display:none" aria-live="polite">
                    <div class="active-filters-chips" id="activeFiltersChips"></div>
                </div>

                <!-- Pet grid -->
                <div class="adopt-pet-grid" id="petsGrid" role="list" aria-label="Available pets"></div>

                <!-- Empty state -->
                <div class="adopt-empty-state" id="emptyState" style="display:none" role="status">
                    <div class="empty-paw">🐾</div>
                    <h3 class="empty-title" data-i18n="adopt-empty-title">No pets match your filters</h3>
                    <p class="empty-desc" data-i18n="adopt-empty-desc">Try adjusting or clearing your filters to see more results.</p>
                    <button class="btn btn-pawdopt-cta" id="emptyStateClearBtn" data-i18n="adopt-empty-clear">Clear All Filters</button>
                </div>

                <!-- Pagination -->
                <div class="adopt-pagination" id="adoptPagination" aria-label="Results pagination"></div>

            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {

    // ── i18n helper ───────────────────────────────────────
    function t(key) {
        var lang = localStorage.getItem('pawdopt-lang') || 'en';
        var dict = window.pawdoptI18n;
        return (dict && dict[lang] && dict[lang][key] !== undefined) ? dict[lang][key] : key;
    }

    // ── Auth state (from server) ──────────────────────────
    var IS_LOGGED_IN = @(User.Identity?.IsAuthenticated == true ? "true" : "false");

    // ── Pet data (shared via pawdopt-data.js) ─────────────
    var PETS = window.PAWDOPT_PETS || [];

    var PAGE_SIZE = 6;

    var state = {
        search:      '',
        breed:       '',
        species:     'all',
        size:        '',
        age:         '',
        genderM:     false,
        genderF:     false,
        vaccinated:  false,
        neutered:    false,
        microchipped:false,
        sort:        'newest',
        page:        1,
        favorites:   new Set(JSON.parse(localStorage.getItem('pawdopt-favs') || '[]'))
    };

    // ── Helpers ───────────────────────────────────────────
    function ageYears(p) { return p.ageUnit === 'mo' ? p.ageNum / 12 : p.ageNum; }

    function ageCategory(p) {
        var y = ageYears(p);
        if (y < 1)  return 'young';
        if (y <= 5) return 'adult';
        return 'senior';
    }

    function capFirst(s) { return s ? s.charAt(0).toUpperCase() + s.slice(1) : ''; }

    // ── Filter & sort ─────────────────────────────────────
    function filterPets() {
        return PETS.filter(function (p) {
            if (state.species !== 'all' && p.species !== state.species) return false;
            if (state.search) {
                var q = state.search.toLowerCase();
                if (!p.name.toLowerCase().includes(q) && !p.breed.toLowerCase().includes(q)) return false;
            }
            if (state.breed) {
                if (!p.breed.toLowerCase().includes(state.breed.toLowerCase())) return false;
            }
            if (state.size && p.size !== state.size) return false;
            if (state.age  && ageCategory(p) !== state.age)  return false;
            if (state.genderM && !state.genderF && p.gender !== 'male')   return false;
            if (!state.genderM && state.genderF && p.gender !== 'female') return false;
            if (state.vaccinated   && !p.vaccinated)   return false;
            if (state.neutered     && !p.neutered)     return false;
            if (state.microchipped && !p.microchipped) return false;
            return true;
        });
    }

    function sortPets(list) {
        var s = list.slice();
        switch (state.sort) {
            case 'az':       return s.sort(function(a,b){ return a.name.localeCompare(b.name); });
            case 'za':       return s.sort(function(a,b){ return b.name.localeCompare(a.name); });
            case 'age-asc':  return s.sort(function(a,b){ return ageYears(a) - ageYears(b); });
            case 'age-desc': return s.sort(function(a,b){ return ageYears(b) - ageYears(a); });
            default: return s.sort(function(a,b){
                var ua = a.badge==='urgent'?2:a.badge==='new'?1:0;
                var ub = b.badge==='urgent'?2:b.badge==='new'?1:0;
                return ub - ua || b.id - a.id;
            });
        }
    }

    // ── Card renderer ─────────────────────────────────────
    function renderCard(p) {
        var isFav = state.favorites.has(p.id);
        var favSvg = isFav
            ? '<svg width="16" height="16" viewBox="0 0 24 24" fill="#ef4444" stroke="#ef4444" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>'
            : '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>';

        var badgeHtml = '';
        if (p.badge === 'new')    badgeHtml = '<span class="pet-badge-new">' + t('pet-badge-new') + '</span>';
        if (p.badge === 'urgent') badgeHtml = '<span class="pet-badge-urgent">' + t('pet-badge-urgent') + '</span>';

        var genderTag = p.gender === 'male'
            ? '<span class="pet-tag pet-tag-male">' + t('tag-male') + '</span>'
            : '<span class="pet-tag pet-tag-female">' + t('tag-female') + '</span>';

        var healthHtml = '';
        if (p.vaccinated)   healthHtml += '<span class="health-badge">' + t('pet-health-vaccinated') + '</span>';
        if (p.neutered)     healthHtml += '<span class="health-badge">' + t('pet-health-neutered') + '</span>';
        if (p.microchipped) healthHtml += '<span class="health-badge">' + t('pet-health-chipped') + '</span>';

        return '<div class="pet-card adopt-pet-card" role="listitem" data-pet-id="' + p.id + '">' +
            '<div class="pet-card-img" style="background:' + p.colors + ';">' +
                badgeHtml +
                '<button class="pet-fav-btn' + (isFav ? ' is-fav' : '') + '" data-fav-id="' + p.id + '" aria-label="' + (isFav ? t('adopt-fav-remove') : t('adopt-fav-save')) + '">' +
                    favSvg +
                '</button>' +
                '<span class="pet-emoji">' + p.emoji + '</span>' +
            '</div>' +
            '<div class="pet-card-body">' +
                '<h5 class="pet-name">' + p.name + '</h5>' +
                '<div class="pet-tags" style="margin-bottom:0.45rem">' +
                    genderTag +
                    '<span class="pet-tag">' + p.breed + '</span>' +
                    '<span class="pet-tag">' + p.ageNum + ' ' + p.ageUnit + '</span>' +
                    '<span class="pet-tag">' + t('tag-' + p.size) + '</span>' +
                '</div>' +
                '<p class="pet-card-desc">' + p.desc + '</p>' +
                '<p class="pet-location">' +
                    '<svg width="11" height="11" viewBox="0 0 24 24" fill="#ef4444"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>' +
                    p.city + ', ' + p.province +
                '</p>' +
                (healthHtml ? '<div class="health-badges">' + healthHtml + '</div>' : '') +
                '<a href="/Home/PetDetail?id=' + p.id + '" class="btn btn-more-info" style="margin-top:0.75rem">' + t('btn-more-info') + '</a>' +
            '</div>' +
        '</div>';
    }

    // ── Pagination ────────────────────────────────────────
    function renderPagination(total, current) {
        var pg = document.getElementById('adoptPagination');
        if (!pg) return;
        var totalPages = Math.ceil(total / PAGE_SIZE);
        if (totalPages <= 1) { pg.innerHTML = ''; return; }

        var html = '<button class="pg-btn pg-arrow" id="pgPrev"' + (current === 1 ? ' disabled' : '') + '>&#8249;</button>';
        for (var i = 1; i <= totalPages; i++) {
            html += '<button class="pg-btn' + (i === current ? ' active' : '') + '" data-pg="' + i + '">' + i + '</button>';
        }
        html += '<button class="pg-btn pg-arrow" id="pgNext"' + (current === totalPages ? ' disabled' : '') + '>&#8250;</button>';
        pg.innerHTML = html;

        pg.querySelectorAll('[data-pg]').forEach(function (btn) {
            btn.addEventListener('click', function () {
                state.page = parseInt(this.dataset.pg, 10);
                render();
                document.getElementById('petsGrid').scrollIntoView({ behavior: 'smooth', block: 'start' });
            });
        });
        var prev = document.getElementById('pgPrev');
        if (prev && !prev.disabled) prev.addEventListener('click', function () { state.page--; render(); });
        var next = document.getElementById('pgNext');
        if (next && !next.disabled) next.addEventListener('click', function () { state.page++; render(); });
    }

    // ── Main render ───────────────────────────────────────
    function render() {
        var filtered = filterPets();
        var sorted   = sortPets(filtered);
        var start    = (state.page - 1) * PAGE_SIZE;
        var visible  = sorted.slice(start, start + PAGE_SIZE);

        var grid     = document.getElementById('petsGrid');
        var empty    = document.getElementById('emptyState');
        var countEl  = document.getElementById('resultsCountNum');

        if (filtered.length === 0) {
            grid.innerHTML = '';
            empty.style.display = '';
        } else {
            empty.style.display = 'none';
            grid.innerHTML = visible.map(renderCard).join('');
            countEl.textContent = filtered.length;

            grid.querySelectorAll('.pet-fav-btn').forEach(function (btn) {
                btn.addEventListener('click', function (e) {
                    e.preventDefault();
                    if (!IS_LOGGED_IN) {
                        window.location.href = '/Account/Login?returnUrl=' + encodeURIComponent(window.location.pathname);
                        return;
                    }
                    var id = parseInt(this.dataset.favId, 10);
                    if (state.favorites.has(id)) state.favorites.delete(id);
                    else state.favorites.add(id);
                    localStorage.setItem('pawdopt-favs', JSON.stringify(Array.from(state.favorites)));
                    render();
                });
            });
        }

        renderPagination(filtered.length, state.page);
        updateChips();
    }

    // ── Active chips ──────────────────────────────────────
    function updateChips() {
        var row   = document.getElementById('activeFiltersRow');
        var chips = document.getElementById('activeFiltersChips');
        var active = [];

        if (state.search)      active.push({ key:'search',      label:'"' + state.search + '"' });
        if (state.breed)       active.push({ key:'breed',       label:capFirst(state.breed) + ' ' + t('adopt-chip-breed-suffix') });
        if (state.size)        active.push({ key:'size',        label:t('tag-' + state.size) });
        if (state.age)         active.push({ key:'age',         label:t('adopt-age-' + state.age) });
        if (state.genderM && !state.genderF) active.push({ key:'genderM', label:t('tag-male') });
        if (!state.genderM && state.genderF) active.push({ key:'genderF', label:t('tag-female') });
        if (state.vaccinated)  active.push({ key:'vaccinated',  label:t('adopt-health-vaccinated') });
        if (state.neutered)    active.push({ key:'neutered',    label:t('adopt-health-neutered') });
        if (state.microchipped)active.push({ key:'microchipped',label:t('adopt-health-microchipped') });

        if (active.length) {
            row.style.display = '';
            chips.innerHTML = active.map(function (f) {
                return '<button class="filter-chip" data-chip-key="' + f.key + '">' +
                    '<span>' + f.label + '</span><span class="chip-remove" aria-hidden="true">&times;</span>' +
                '</button>';
            }).join('');
            chips.querySelectorAll('.filter-chip').forEach(function (chip) {
                chip.addEventListener('click', function () {
                    var k = this.dataset.chipKey;
                    if (k === 'search')       { state.search = '';       var si = document.getElementById('searchInput'); if(si) si.value=''; }
                    else if (k === 'breed')   { state.breed = '';        var bi = document.getElementById('breedInput');  if(bi) bi.value=''; }
                    else if (k === 'size')    { state.size = '';  syncSbPills('size'); }
                    else if (k === 'age')     { state.age = '';   syncSbPills('age'); }
                    else if (k === 'genderM') { state.genderM = false; document.getElementById('checkMale').checked   = false; }
                    else if (k === 'genderF') { state.genderF = false; document.getElementById('checkFemale').checked = false; }
                    else if (k === 'vaccinated')  { state.vaccinated   = false; document.getElementById('checkVaccinated').checked   = false; }
                    else if (k === 'neutered')    { state.neutered     = false; document.getElementById('checkNeutered').checked     = false; }
                    else if (k === 'microchipped'){ state.microchipped = false; document.getElementById('checkMicrochipped').checked = false; }
                    state.page = 1; render();
                });
            });
        } else {
            row.style.display = 'none';
        }
    }

    // ── Sync helpers ──────────────────────────────────────
    function syncSbPills(filter) {
        document.querySelectorAll('.sb-pill[data-filter="' + filter + '"]').forEach(function (btn) {
            btn.classList.toggle('active', btn.dataset.val === state[filter]);
        });
    }

    function syncSpeciesBtns() {
        document.querySelectorAll('.sb-type-btn').forEach(function (btn) {
            btn.classList.toggle('active', btn.dataset.species === state.species);
        });
    }

    function clearAll() {
        state.search = ''; state.breed = ''; state.species = 'all';
        state.size = ''; state.age = ''; state.genderM = false; state.genderF = false;
        state.vaccinated = false; state.neutered = false; state.microchipped = false;
        state.page = 1;
        var si = document.getElementById('searchInput'); if(si) si.value = '';
        var bi = document.getElementById('breedInput');  if(bi) bi.value = '';
        document.getElementById('checkMale').checked        = false;
        document.getElementById('checkFemale').checked      = false;
        document.getElementById('checkVaccinated').checked  = false;
        document.getElementById('checkNeutered').checked    = false;
        document.getElementById('checkMicrochipped').checked= false;
        syncSpeciesBtns();
        syncSbPills('size');
        syncSbPills('age');
        render();
    }

    // ── Event wiring ──────────────────────────────────────

    // Species type buttons
    document.querySelectorAll('.sb-type-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
            state.species = this.dataset.species;
            state.page = 1;
            syncSpeciesBtns();
            render();
        });
    });

    // Size + Age pills
    document.querySelectorAll('.sb-pill[data-filter]').forEach(function (btn) {
        btn.addEventListener('click', function () {
            var filter = this.dataset.filter;
            var val    = this.dataset.val;
            state[filter] = val;
            state.page = 1;
            syncSbPills(filter);
            render();
        });
    });

    // Gender checkboxes
    document.getElementById('checkMale').addEventListener('change', function ()   { state.genderM = this.checked; state.page=1; render(); });
    document.getElementById('checkFemale').addEventListener('change', function () { state.genderF = this.checked; state.page=1; render(); });

    // Health checkboxes
    document.getElementById('checkVaccinated').addEventListener('change',   function () { state.vaccinated   = this.checked; state.page=1; render(); });
    document.getElementById('checkNeutered').addEventListener('change',     function () { state.neutered     = this.checked; state.page=1; render(); });
    document.getElementById('checkMicrochipped').addEventListener('change', function () { state.microchipped = this.checked; state.page=1; render(); });

    // Breed input (debounced)
    var breedTimer;
    document.getElementById('breedInput').addEventListener('input', function () {
        clearTimeout(breedTimer);
        var val = this.value;
        breedTimer = setTimeout(function () { state.breed = val.trim(); state.page=1; render(); }, 280);
    });

    // Distance slider (visual only)
    document.getElementById('distanceSlider').addEventListener('input', function () {
        document.getElementById('distanceVal').textContent = this.value + ' km';
    });

    // Sort
    document.getElementById('sortSelect').addEventListener('change', function () { state.sort = this.value; render(); });

    // Search input + button
    var searchTimer;
    var searchInput = document.getElementById('searchInput');
    searchInput.addEventListener('input', function () {
        clearTimeout(searchTimer);
        var val = this.value;
        searchTimer = setTimeout(function () { state.search = val.trim(); state.page=1; render(); }, 280);
    });
    searchInput.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { clearTimeout(searchTimer); state.search = this.value.trim(); state.page=1; render(); }
    });
    document.getElementById('searchBtn').addEventListener('click', function () {
        clearTimeout(searchTimer); state.search = searchInput.value.trim(); state.page=1; render();
    });

    // Apply + Reset buttons
    document.getElementById('applyFiltersBtn').addEventListener('click', function () { state.page=1; render(); });
    document.getElementById('resetFiltersBtn').addEventListener('click', clearAll);
    document.getElementById('emptyStateClearBtn').addEventListener('click', clearAll);

    // Re-render cards when language changes
    document.addEventListener('pawdopt:langchange', function () { render(); });

    // Initial render
    syncSbPills('size');
    syncSbPills('age');
    render();

})();
</script>
}
