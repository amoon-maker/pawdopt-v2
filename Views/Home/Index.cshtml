<!-- How It Works -->
<section class="how-section">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-eyebrow">SIMPLE PROCESS</span>
            <h2 class="section-title">Adopt or Rehome in 3 easy steps</h2>
        </div>
        <div class="row justify-content-center align-items-center g-0 how-steps-row">
            <div class="col-12 col-md-3 how-step text-center">
                <div class="how-step-circle">1</div>
                <h4 class="how-step-title">Create your profile</h4>
                <p class="how-step-desc">Register and set up your adopter or rehomer account in minutes</p>
            </div>
            <div class="col-12 col-md-1 how-arrow d-none d-md-flex">
                <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28M22 2l8 6-8 6" stroke="#CBD5E0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="col-12 col-md-3 how-step text-center">
                <div class="how-step-circle">2</div>
                <h4 class="how-step-title">Browse &amp; match</h4>
                <p class="how-step-desc">Filter pets by breed, size, age and location to find the right fit</p>
            </div>
            <div class="col-12 col-md-1 how-arrow d-none d-md-flex">
                <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28M22 2l8 6-8 6" stroke="#CBD5E0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="col-12 col-md-3 how-step text-center">
                <div class="how-step-circle">3</div>
                <h4 class="how-step-title">Start the process</h4>
                <p class="how-step-desc">Submit a structured application and connect with the pet's owner</p>
            </div>
        </div>
    </div>
</section>

