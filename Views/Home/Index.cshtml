@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container hero-container">
        <div class="row align-items-center hero-row">

            <div class="col-lg-6 hero-content">
                <div class="hero-badge">
                    <span class="hero-badge-icon">🐾</span>
                    Quebec's pet adoption platform
                </div>
                <h1 class="hero-title">
                    Give a new life to<br>
                    an animal with<br>
                    <span class="hero-title-brand">Pawdopt</span>
                </h1>
                <p class="hero-subtitle">
                    Pet adoption and rehoming are both vital aspects of animal
                    welfare. Find your perfect companion or safely rehome your
                    pet through our trusted platform.
                </p>
                <div class="hero-actions">
                    <a href="#" class="btn btn-hero-primary"><span>🐾</span> Adopt Now</a>
                    <a href="#" class="btn btn-hero-secondary"><span>🏠</span> Rehome a Pet</a>
                </div>
            </div>

            <div class="col-lg-6 d-flex justify-content-center justify-content-lg-end">
                <div class="hero-card">
                    <div class="hero-card-inner">
                        <div class="hero-dog-wrap">
                            <span class="hero-dog-emoji">🐕</span>
                        </div>
                        <div class="hero-stats-badge">
                            <span class="hero-stats-icon">🐾</span>
                            <div class="hero-stats-text">
                                <span class="hero-stats-number">2,400+</span>
                                <span class="hero-stats-label">pets adopted</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- Stats Bar -->
<section class="stats-bar">
    <div class="container">
        <div class="row text-center g-0">
            <div class="col-6 col-md-3 stats-item">
                <span class="stats-number">2,400+</span>
                <span class="stats-label">Pets Adopted</span>
            </div>
            <div class="col-6 col-md-3 stats-item">
                <span class="stats-number">500+</span>
                <span class="stats-label">Active Listings</span>
            </div>
            <div class="col-6 col-md-3 stats-item">
                <span class="stats-number">1,200+</span>
                <span class="stats-label">Happy Families</span>
            </div>
            <div class="col-6 col-md-3 stats-item">
                <span class="stats-number">50+</span>
