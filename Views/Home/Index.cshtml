<!-- FAQ -->
<section class="faq-section">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-eyebrow" data-i18n="faq-eyebrow">GOT QUESTIONS?</span>
            <h2 class="section-title" data-i18n="faq-title">Frequently asked questions</h2>
        </div>
        <div class="faq-list">

            <div class="faq-item">
                <button class="faq-btn" data-faq="1" aria-expanded="false">
                    <span data-i18n="faq-q1">Why are you only helping dogs and cats?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer" id="faq-1">
                    <p data-i18n="faq-a1">We started with dogs and cats as they represent the largest share of animals needing rehoming in Quebec. We plan to expand to other animals in future releases.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-btn" data-faq="2" aria-expanded="false">
                    <span data-i18n="faq-q2">Will you carry out a home check before adoption?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer" id="faq-2">
                    <p data-i18n="faq-a2">Our platform facilitates direct communication between adopters and rehomers. A home visit is encouraged and can be arranged between parties, though it is not mandatory for all listings.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-btn" data-faq="3" aria-expanded="false">
                    <span data-i18n="faq-q3">How do I know my rehomed pet is safe?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer" id="faq-3">
                    <p data-i18n="faq-a3">All adopter profiles are verified and we provide a structured application process. You can review the adopter's profile, ask questions, and arrange a meet-and-greet before making a decision.</p>
                </div>
            </div>

            <div class="faq-item">
                <button class="faq-btn" data-faq="4" aria-expanded="false">
                    <span data-i18n="faq-q4">Can I message the pet owner before applying?</span>
                    <span class="faq-icon">+</span>
                </button>
                <div class="faq-answer" id="faq-4">
                    <p data-i18n="faq-a4">Yes! Registered users can send messages directly to pet owners or shelters through our in-platform messaging system before submitting a formal adoption application.</p>
                </div>
            </div>

        </div>
    </div>
</section>

