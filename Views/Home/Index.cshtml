@{
    ViewData["Title"] = "Home";
}

<!-- Hero Section -->
<section class="hero-section">
    <div class="container hero-container">
        <div class="row align-items-center hero-row">

            <div class="col-lg-6 hero-content">
                <div class="hero-badge">
                    <span class="hero-badge-icon">🐾</span>
                    <span data-i18n="hero-badge">Quebec's pet adoption platform</span>
                </div>
                <h1 class="hero-title" data-i18n-html="hero-title">
                    Give a new life to<br>
                    an animal with<br>
                    <span class="hero-title-brand">Pawdopt</span>
                </h1>
                <p class="hero-subtitle" data-i18n="hero-subtitle">
                    Pet adoption and rehoming are both vital aspects of animal
                    welfare. Find your perfect companion or safely rehome your
                    pet through our trusted platform.
                </p>
                <div class="hero-actions">
                    <a asp-controller="Home" asp-action="Adopt" class="btn btn-hero-primary">
                        <span data-i18n="hero-btn-adopt">Adopt Now</span>
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                    </a>
                    <a asp-controller="Rehome" asp-action="List" class="btn btn-hero-secondary">
                        <span data-i18n="hero-btn-rehome">Rehome a Pet</span>
                    </a>
                </div>
            </div>

            <div class="col-lg-6 d-flex justify-content-center justify-content-lg-end">
                <div class="hero-card">
                    <div class="hero-card-inner">
                        <div class="hero-dog-wrap">
                            <img src="~/images/hero-pets.png" alt="Pets" class="hero-dog-img" />
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- How It Works -->
<section class="how-section">
    <div class="container">
        <div class="section-header text-center">
            <span class="section-eyebrow" data-i18n="how-eyebrow">SIMPLE PROCESS</span>
            <h2 class="section-title" data-i18n="how-title">Adopt or Rehome in 3 easy steps</h2>
        </div>
        <div class="row justify-content-center align-items-center g-0 how-steps-row">
            <div class="col-12 col-md-3 how-step text-center">
                <div class="how-step-circle">1</div>
                <h4 class="how-step-title" data-i18n="how-step1-title">Create your profile</h4>
                <p class="how-step-desc" data-i18n="how-step1-desc">Register and set up your adopter or rehomer account in minutes</p>
            </div>
            <div class="col-12 col-md-1 how-arrow d-none d-md-flex">
                <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28M22 2l8 6-8 6" stroke="#CBD5E0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="col-12 col-md-3 how-step text-center">
                <div class="how-step-circle">2</div>
                <h4 class="how-step-title" data-i18n="how-step2-title">Browse &amp; match</h4>
                <p class="how-step-desc" data-i18n="how-step2-desc">Filter pets by breed, size, age and location to find the right fit</p>
            </div>
            <div class="col-12 col-md-1 how-arrow d-none d-md-flex">
                <svg width="32" height="16" viewBox="0 0 32 16" fill="none"><path d="M0 8h28M22 2l8 6-8 6" stroke="#CBD5E0" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </div>
            <div class="col-12 col-md-3 how-step text-center">
                <div class="how-step-circle">3</div>
                <h4 class="how-step-title" data-i18n="how-step3-title">Start the process</h4>
                <p class="how-step-desc" data-i18n="how-step3-desc">Submit a structured application and connect with the pet's owner</p>
            </div>
        </div>
    </div>
</section>

