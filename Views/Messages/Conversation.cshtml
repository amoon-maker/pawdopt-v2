@model List<PawdoptApp.Models.Message>
@{
    ViewData["Title"] = "Conversation";
    var myId        = ViewData["UserId"]      as string ?? "";
    var partnerId   = ViewData["PartnerId"]   as string ?? "";
    var partnerName = ViewData["PartnerName"] as string ?? "User";
    var listingId   = ViewData["ListingId"]   as int?;
    var partnerInit = partnerName.Substring(0, 1).ToUpper();
}

<div class="msg-page">
    <div class="adopt-pg-container" style="max-width:780px">

        <!-- Thread header -->
        <div class="msg-convo-header">
            <a href="/Messages" class="msg-back-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </a>
            <div class="msg-convo-avatar">@partnerInit</div>
            <div class="msg-convo-info">
                <div class="msg-convo-name">@partnerName</div>
                @if (listingId.HasValue)
                {
                    <div class="msg-convo-context">re: listing #@listingId</div>
                }
            </div>
        </div>

        <!-- Messages -->
        <div class="msg-bubble-list" id="bubbleList">
            @if (!Model.Any())
            {
                <div class="msg-bubble-empty">Start the conversation!</div>
            }

            @foreach (var msg in Model)
            {
                var isMine = msg.SenderId == myId;
                <div class="msg-bubble-row @(isMine ? "mine" : "theirs")">
                    @if (!isMine)
                    {
                        <div class="msg-bubble-avatar">@partnerInit</div>
                    }
                    <div class="msg-bubble">
                        <div class="msg-bubble-body">@msg.Body</div>
                        <div class="msg-bubble-time">@msg.SentAt.ToLocalTime().ToString("h:mm tt")</div>
                    </div>
                </div>
            }
        </div>

        <!-- Send form -->
        <form class="msg-send-form" method="post" asp-controller="Messages" asp-action="Send">
            @Html.AntiForgeryToken()
            <input type="hidden" name="receiverId" value="@partnerId" />
            @if (listingId.HasValue)
            {
                <input type="hidden" name="listingId" value="@listingId" />
            }
            <textarea class="msg-send-input" name="body" id="msgBody"
                placeholder="Write a message…" rows="1" required></textarea>
            <button type="submit" class="msg-send-btn" id="msgSendBtn" disabled>
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
        </form>

    </div>
</div>

@section Scripts {
<script>
(function () {
    // Scroll to bottom
    var list = document.getElementById('bubbleList');
    if (list) list.scrollTop = list.scrollHeight;

    // Enable send button only when there's text
    var textarea = document.getElementById('msgBody');
    var sendBtn  = document.getElementById('msgSendBtn');
    textarea.addEventListener('input', function () {
        sendBtn.disabled = this.value.trim() === '';
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 120) + 'px';
    });

    // Submit on Enter (Shift+Enter for newline)
    textarea.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            if (this.value.trim()) this.closest('form').submit();
        }
    });
})();
</script>
}
