@{
    ViewData["Title"] = "Character & Health";
    var listingId = (int)(ViewData["ListingId"] ?? 0);
}

<!-- Teal progress banner -->
<div class="rw-banner">
    <div class="rw-banner-inner">
        <div class="rw-banner-left">
            <span class="rw-banner-step">Step 3 of 5</span>
            <span class="rw-banner-sep">·</span>
            <span class="rw-banner-name">Character &amp; health</span>
        </div>
        <div class="rw-banner-bar"><div class="rw-banner-fill" style="width:60%"></div></div>
    </div>
</div>

<div class="rehome-page">
    <div class="rehome-container">

        <!-- Breadcrumb -->
        <nav class="rehome-breadcrumb" aria-label="breadcrumb">
            <a href="/" data-i18n="nav-home">Home</a>
            <span class="bc-sep">›</span>
            <a href="/Rehome/List" data-i18n="nav-rehome">Rehome</a>
            <span class="bc-sep">›</span>
            <span class="bc-current">Character &amp; health</span>
        </nav>

        <!-- Step progress -->
        <div class="rehome-stepper" role="list">
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Pet info</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Photos</span>
            </div>
            <div class="step-item active" role="listitem">
                <div class="step-circle">3</div>
                <span class="step-label">Character</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">4</div>
                <span class="step-label">Location</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">5</div>
                <span class="step-label">Confirm</span>
            </div>
        </div>

        <!-- Form card -->
        <div class="rehome-card">
            <div class="rehome-card-header">
                <h1 class="rehome-card-title">Character &amp; health</h1>
                <p class="rehome-card-subtitle">
                    <span class="step-pill">Step 3 of 5</span>
                    <span>Help adopters understand your pet's personality and health needs.</span>
                </p>
            </div>

            <form method="post" asp-controller="Rehome" asp-action="SaveStep3" asp-route-id="@listingId">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@listingId" />
                <div class="rehome-char-body">

                    <!-- ── Section 1: Personality ──────────────────── -->
                    <div class="rw-section-hdr">
                        <span class="rw-section-icon">🐾</span>
                        <div>
                            <p class="rw-section-title">Personality traits</p>
                            <p class="rw-section-sub">Select all that apply — adopters love knowing what to expect</p>
                        </div>
                    </div>

                    <div class="char-traits-grid">
                        <button type="button" class="char-trait-chip" data-trait="playful">
                            <span class="chip-icon">🎾</span><span data-i18n="trait-playful">Playful</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="calm">
                            <span class="chip-icon">😌</span><span data-i18n="trait-calm">Calm</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="energetic">
                            <span class="chip-icon">⚡</span><span data-i18n="trait-energetic">Energetic</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="affectionate">
                            <span class="chip-icon">💕</span><span data-i18n="trait-affectionate">Affectionate</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="shy">
                            <span class="chip-icon">🙈</span><span data-i18n="trait-shy">Shy</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="loyal">
                            <span class="chip-icon">💛</span><span data-i18n="trait-loyal">Loyal</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="gentle">
                            <span class="chip-icon">🌸</span><span data-i18n="trait-gentle">Gentle</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="curious">
                            <span class="chip-icon">👀</span><span data-i18n="trait-curious">Curious</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="kids">
                            <span class="chip-icon">👶</span><span data-i18n="trait-kids">Good with kids</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="dogs">
                            <span class="chip-icon">🐕</span><span data-i18n="trait-dogs">Good with dogs</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="cats">
                            <span class="chip-icon">🐈</span><span data-i18n="trait-cats">Good with cats</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="trained">
                            <span class="chip-icon">🏠</span><span data-i18n="trait-trained">House-trained</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="outdoors">
                            <span class="chip-icon">🌿</span><span data-i18n="trait-outdoors">Loves outdoors</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="independent">
                            <span class="chip-icon">🦅</span><span data-i18n="trait-independent">Independent</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="vocal">
                            <span class="chip-icon">🔊</span><span data-i18n="trait-vocal">Vocal</span>
                        </button>
                        <button type="button" class="char-trait-chip" data-trait="quiet">
                            <span class="chip-icon">🤫</span><span data-i18n="trait-quiet">Quiet</span>
                        </button>
                    </div>
                    <div id="traitInputs"></div>

                    <div class="mb-3 mt-3">
                        <label class="rehome-label" data-i18n="rehome-char-notes-label">Anything else about their personality?</label>
                        <textarea class="rehome-textarea" name="characterNotes"
                            data-i18n-placeholder="rehome-char-notes-placeholder"
                            placeholder="e.g. loves cuddles, gets anxious in thunderstorms..."></textarea>
                    </div>

                    <!-- ── Section 2: Health & lifestyle ──────────── -->
                    <hr class="rw-section-divider">

                    <div class="rw-section-hdr">
                        <span class="rw-section-icon">🏥</span>
                        <div>
                            <p class="rw-section-title">Health &amp; lifestyle</p>
                            <p class="rw-section-sub">Let adopters know about medical history and daily needs</p>
                        </div>
                    </div>

                    <!-- Vaccinated + Sterilized -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="rehome-label" data-i18n="rehome-kf-label-vaccinated">Vaccinated?</label>
                            <select class="rehome-select" name="vaccinated" required>
                                <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                                <option value="yes" data-i18n="rehome-kf-opt-vaccinated-yes">Yes, fully vaccinated</option>
                                <option value="partial" data-i18n="rehome-kf-opt-vaccinated-partial">Partially vaccinated</option>
                                <option value="no" data-i18n="rehome-kf-opt-vaccinated-no">Not vaccinated</option>
                                <option value="unknown" data-i18n="rehome-kf-opt-vaccinated-unknown">Unknown</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="rehome-label" data-i18n="rehome-kf-label-sterilized">Spayed / Neutered?</label>
                            <select class="rehome-select" name="sterilized" required>
                                <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                                <option value="yes" data-i18n="rehome-kf-opt-sterilized-yes">Yes</option>
                                <option value="no" data-i18n="rehome-kf-opt-sterilized-no">No</option>
                                <option value="unknown" data-i18n="rehome-kf-opt-sterilized-unknown">Unknown</option>
                            </select>
                        </div>
                    </div>

                    <!-- Activity level -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-kf-label-activity">Activity level</label>
                        <div class="option-chips" data-group="activity">
                            <button type="button" class="option-chip" data-value="low">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-activity-low">Low</span>
                            </button>
                            <button type="button" class="option-chip" data-value="moderate">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-activity-moderate">Moderate</span>
                            </button>
                            <button type="button" class="option-chip" data-value="high">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-activity-high">High</span>
                            </button>
                        </div>
                        <input type="hidden" name="activityLevel" id="activityLevel" />
                    </div>

                    <!-- Training level -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-kf-label-training">Training level</label>
                        <div class="option-chips" data-group="training">
                            <button type="button" class="option-chip" data-value="none">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-training-none">Not trained</span>
                            </button>
                            <button type="button" class="option-chip" data-value="basic">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-training-basic">Basic commands</span>
                            </button>
                            <button type="button" class="option-chip" data-value="well">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-training-well">Well trained</span>
                            </button>
                        </div>
                        <input type="hidden" name="trainingLevel" id="trainingLevel" />
                    </div>

                    <!-- Ideal home -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-kf-label-home">Ideal home</label>
                        <div class="option-chips" data-group="home">
                            <button type="button" class="option-chip" data-value="apartment">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-home-apartment">Apartment</span>
                            </button>
                            <button type="button" class="option-chip" data-value="house">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-home-house">House + yard</span>
                            </button>
                            <button type="button" class="option-chip" data-value="any">
                                <span class="chip-dot"></span><span data-i18n="rehome-kf-home-any">Any home</span>
                            </button>
                        </div>
                        <input type="hidden" name="idealHome" id="idealHome" />
                    </div>

                    <!-- Health notes -->
                    <div class="mb-0">
                        <label class="rehome-label" data-i18n="rehome-kf-label-health">Health &amp; medical notes</label>
                        <textarea class="rehome-textarea" name="healthNotes"
                            data-i18n-placeholder="rehome-kf-health-placeholder"
                            placeholder="Any known conditions, allergies, medications..."></textarea>
                    </div>

                    <div class="rehome-divider"></div>

                    <div class="rehome-nav-btns">
                        <a href="/Rehome/Images/@listingId" class="rehome-btn-back">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                            <span data-i18n="rehome-btn-back">Back</span>
                        </a>
                        <button type="submit" class="rehome-btn-continue">
                            <span data-i18n="rehome-btn-continue">Save &amp; Continue →</span>
                        </button>
                    </div>

                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    // Trait chips
    const chips = document.querySelectorAll('.char-trait-chip');
    const inputsContainer = document.getElementById('traitInputs');
    chips.forEach(function (chip) {
        chip.addEventListener('click', function () {
            chip.classList.toggle('selected');
            syncTraits();
        });
    });
    function syncTraits() {
        inputsContainer.innerHTML = '';
        document.querySelectorAll('.char-trait-chip.selected').forEach(function (chip) {
            const input = document.createElement('input');
            input.type = 'hidden';
            input.name = 'traits';
            input.value = chip.getAttribute('data-trait');
            inputsContainer.appendChild(input);
        });
    }

    // Option chips (activity, training, home)
    document.querySelectorAll('.option-chips').forEach(function (group) {
        const groupName = group.getAttribute('data-group');
        const hiddenInput = document.getElementById(
            groupName === 'activity' ? 'activityLevel' :
            groupName === 'training' ? 'trainingLevel' : 'idealHome'
        );
        group.querySelectorAll('.option-chip').forEach(function (chip) {
            chip.addEventListener('click', function () {
                group.querySelectorAll('.option-chip').forEach(c => c.classList.remove('selected'));
                chip.classList.add('selected');
                if (hiddenInput) hiddenInput.value = chip.getAttribute('data-value');
            });
        });
    });

    // Step 3 validation
    var form = document.querySelector('form[action="/Rehome/SaveStep3"]');
    var errorBanner = null;

    function showError(msg) {
        if (!errorBanner) {
            errorBanner = document.createElement('div');
            errorBanner.className = 'rw-step-error';
            form.insertBefore(errorBanner, form.firstChild);
        }
        errorBanner.textContent = msg;
        errorBanner.style.display = 'flex';
        errorBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    form.setAttribute('novalidate', '');
    form.addEventListener('submit', function (e) {
        var lang = localStorage.getItem('pawdopt-lang') || 'en';
        var fr = lang === 'fr';

        var vaccinated = form.querySelector('[name="vaccinated"]').value;
        var sterilized = form.querySelector('[name="sterilized"]').value;
        var activity   = document.getElementById('activityLevel').value;
        var hasTraits  = document.querySelectorAll('.char-trait-chip.selected').length > 0;

        if (!hasTraits) {
            e.preventDefault();
            showError(fr ? 'Veuillez sélectionner au moins un trait de personnalité.' : 'Please select at least one personality trait.');
            return;
        }
        if (!vaccinated) {
            e.preventDefault();
            showError(fr ? 'Veuillez indiquer le statut vaccinal.' : 'Please indicate the vaccination status.');
            return;
        }
        if (!sterilized) {
            e.preventDefault();
            showError(fr ? 'Veuillez indiquer si l\'animal est stérilisé.' : 'Please indicate if your pet is spayed/neutered.');
            return;
        }
        if (!activity) {
            e.preventDefault();
            showError(fr ? 'Veuillez sélectionner le niveau d\'activité.' : 'Please select an activity level.');
            return;
        }
    });
})();
</script>
}
