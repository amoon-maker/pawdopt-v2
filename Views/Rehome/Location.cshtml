@model PawdoptApp.Models.PetListing
@{
    ViewData["Title"] = "Location";
    var listingId = (int)(ViewData["ListingId"] ?? 0);
}

<!-- Teal progress banner -->
<div class="rw-banner">
    <div class="rw-banner-inner">
        <div class="rw-banner-left">
            <span class="rw-banner-step">Step 4 of 5</span>
            <span class="rw-banner-sep">·</span>
            <span class="rw-banner-name">Location</span>
        </div>
        <div class="rw-banner-bar"><div class="rw-banner-fill" style="width:80%"></div></div>
    </div>
</div>

<div class="rehome-page">
    <div class="rehome-container">

        <!-- Breadcrumb -->
        <nav class="rehome-breadcrumb" aria-label="breadcrumb">
            <a href="/" data-i18n="nav-home">Home</a>
            <span class="bc-sep">›</span>
            <a href="/Rehome/List" data-i18n="nav-rehome">Rehome</a>
            <span class="bc-sep">›</span>
            <span class="bc-current">Location</span>
        </nav>

        <!-- Step progress -->
        <div class="rehome-stepper" role="list">
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Pet info</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Photos</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Character</span>
            </div>
            <div class="step-item active" role="listitem">
                <div class="step-circle">4</div>
                <span class="step-label">Location</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">5</div>
                <span class="step-label">Confirm</span>
            </div>
        </div>

        <!-- Form card -->
        <div class="rehome-card">
            <div class="rehome-card-header">
                <h1 class="rehome-card-title">Location</h1>
                <p class="rehome-card-subtitle">
                    <span class="step-pill">Step 4 of 5</span>
                    <span>Where is your pet located?</span>
                </p>
            </div>

            <form method="post" asp-controller="Rehome" asp-action="SaveStep5" asp-route-id="@listingId">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@listingId" />
                <div class="rehome-kf-body">

                    <!-- ── Section 1: Location ─────────────────────── -->
                    <div class="rw-section-hdr">
                        <span class="rw-section-icon">📍</span>
                        <div>
                            <p class="rw-section-title">Location</p>
                            <p class="rw-section-sub">Adopters use this to find pets near them — only city &amp; province shown publicly</p>
                        </div>
                    </div>

                    <!-- City + Province + Postal -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-5">
                            <label class="rehome-label" data-i18n="rehome-loc-label-city">City / Town</label>
                            <input type="text" class="rehome-input" name="city" value="@Model?.City"
                                data-i18n-placeholder="rehome-loc-city-placeholder"
                                placeholder="Montréal" required />
                        </div>
                        <div class="col-md-4">
                            <label class="rehome-label" data-i18n="rehome-loc-label-province">Province</label>
                            <select class="rehome-select" name="province" required>
                                <option value="" disabled selected="@(string.IsNullOrEmpty(Model?.Province))" data-i18n="rehome-select-default">Select...</option>
                                <option value="QC" selected="@(Model?.Province == "QC")">Québec</option>
                                <option value="ON" selected="@(Model?.Province == "ON")">Ontario</option>
                                <option value="BC" selected="@(Model?.Province == "BC")">British Columbia</option>
                                <option value="AB" selected="@(Model?.Province == "AB")">Alberta</option>
                                <option value="MB" selected="@(Model?.Province == "MB")">Manitoba</option>
                                <option value="SK" selected="@(Model?.Province == "SK")">Saskatchewan</option>
                                <option value="NS" selected="@(Model?.Province == "NS")">Nova Scotia</option>
                                <option value="NB" selected="@(Model?.Province == "NB")">New Brunswick</option>
                                <option value="NL" selected="@(Model?.Province == "NL")">Newfoundland</option>
                                <option value="PE" selected="@(Model?.Province == "PE")">PEI</option>
                                <option value="NT" selected="@(Model?.Province == "NT")">Northwest Territories</option>
                                <option value="YT" selected="@(Model?.Province == "YT")">Yukon</option>
                                <option value="NU" selected="@(Model?.Province == "NU")">Nunavut</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="rehome-label" data-i18n="rehome-loc-label-postal">Postal Code</label>
                            <input type="text" class="rehome-input" name="postalCode" value="@Model?.PostalCode"
                                data-i18n-placeholder="rehome-loc-postal-placeholder"
                                placeholder="H1A 0A1" maxlength="7" />
                        </div>
                    </div>

                    <!-- Pickup arrangements -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-loc-label-pickup">Pickup arrangements</label>
                        <div class="option-chips" data-group="pickup">
                            <button type="button" class="option-chip@(Model?.PickupType == "home" ? " selected" : "")" data-value="home">
                                <span class="chip-dot"></span><span data-i18n="rehome-loc-pickup-home">Home pickup</span>
                            </button>
                            <button type="button" class="option-chip@(Model?.PickupType == "neutral" ? " selected" : "")" data-value="neutral">
                                <span class="chip-dot"></span><span data-i18n="rehome-loc-pickup-neutral">Neutral location</span>
                            </button>
                            <button type="button" class="option-chip@(Model?.PickupType == "adopter" ? " selected" : "")" data-value="adopter">
                                <span class="chip-dot"></span><span data-i18n="rehome-loc-pickup-adopter">Adopter's place</span>
                            </button>
                        </div>
                        <input type="hidden" name="pickupType" id="pickupType" value="@Model?.PickupType" />
                    </div>

                    <div class="mb-3">
                        <textarea class="rehome-textarea" name="pickupNotes"
                            data-i18n-placeholder="rehome-loc-pickup-placeholder"
                            placeholder="e.g. Can meet at a neutral location, home pickup available on weekends...">@Model?.PickupNotes</textarea>
                    </div>

                    <!-- Privacy note -->
                    <div class="loc-privacy-note mb-4">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        <span data-i18n="rehome-loc-privacy-note">Only your city and province are shown publicly. Your exact address is never shared.</span>
                    </div>

                    <div class="rehome-divider"></div>

                    <div class="rehome-nav-btns">
                        <a href="/Rehome/Character/@listingId" class="rehome-btn-back">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                            <span data-i18n="rehome-btn-back">Back</span>
                        </a>
                        <button type="submit" class="rehome-btn-continue">
                            <span data-i18n="rehome-btn-continue">Save &amp; Continue →</span>
                        </button>
                    </div>

                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    // Pickup option chips
    document.querySelectorAll('.option-chips').forEach(function (group) {
        const hiddenInput = document.getElementById('pickupType');
        group.querySelectorAll('.option-chip').forEach(function (chip) {
            chip.addEventListener('click', function () {
                group.querySelectorAll('.option-chip').forEach(c => c.classList.remove('selected'));
                chip.classList.add('selected');
                if (hiddenInput) hiddenInput.value = chip.getAttribute('data-value');
            });
        });
    });

    // Step 4 validation
    var form = document.querySelector('form[action="/Rehome/SaveStep5"]');
    var errorBanner = null;

    function showError(msg) {
        if (!errorBanner) {
            errorBanner = document.createElement('div');
            errorBanner.className = 'rw-step-error';
            form.insertBefore(errorBanner, form.firstChild);
        }
        errorBanner.textContent = msg;
        errorBanner.style.display = 'flex';
        errorBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    form.setAttribute('novalidate', '');
    form.addEventListener('submit', function (e) {
        var lang = localStorage.getItem('pawdopt-lang') || 'en';
        var fr = lang === 'fr';

        var city     = form.querySelector('[name="city"]').value.trim();
        var province = form.querySelector('[name="province"]').value;

        if (!city) {
            e.preventDefault();
            showError(fr ? 'Veuillez entrer votre ville.' : 'Please enter your city.');
            return;
        }
        if (!province) {
            e.preventDefault();
            showError(fr ? 'Veuillez sélectionner votre province.' : 'Please select a province.');
            return;
        }
    });
})();
</script>
}
