@{
    ViewData["Title"] = "Location & Story";
}

<!-- Teal progress banner -->
<div class="rw-banner">
    <div class="rw-banner-inner">
        <div class="rw-banner-left">
            <span class="rw-banner-step">Step 4 of 5</span>
            <span class="rw-banner-sep">·</span>
            <span class="rw-banner-name">Location &amp; story</span>
        </div>
        <div class="rw-banner-bar"><div class="rw-banner-fill" style="width:80%"></div></div>
    </div>
</div>

<div class="rehome-page">
    <div class="rehome-container">

        <!-- Breadcrumb -->
        <nav class="rehome-breadcrumb" aria-label="breadcrumb">
            <a href="/" data-i18n="nav-home">Home</a>
            <span class="bc-sep">›</span>
            <a href="/Rehome/List" data-i18n="nav-rehome">Rehome</a>
            <span class="bc-sep">›</span>
            <span class="bc-current">Location &amp; story</span>
        </nav>

        <!-- Step progress -->
        <div class="rehome-stepper" role="list">
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Pet info</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Photos</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label">Character</span>
            </div>
            <div class="step-item active" role="listitem">
                <div class="step-circle">4</div>
                <span class="step-label">Location</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">5</div>
                <span class="step-label">Confirm</span>
            </div>
        </div>

        <!-- Form card -->
        <div class="rehome-card">
            <div class="rehome-card-header">
                <h1 class="rehome-card-title">Location &amp; story</h1>
                <p class="rehome-card-subtitle">
                    <span class="step-pill">Step 4 of 5</span>
                    <span>Where is your pet and what's their story?</span>
                </p>
            </div>

            <form method="post" action="/Rehome/SaveStep5">
                <div class="rehome-kf-body">

                    <!-- ── Section 1: Location ─────────────────────── -->
                    <div class="rw-section-hdr">
                        <span class="rw-section-icon">📍</span>
                        <div>
                            <p class="rw-section-title">Location</p>
                            <p class="rw-section-sub">Adopters use this to find pets near them — only city &amp; province shown publicly</p>
                        </div>
                    </div>

                    <!-- City + Province + Postal -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-5">
                            <label class="rehome-label" data-i18n="rehome-loc-label-city">City / Town</label>
                            <input type="text" class="rehome-input" name="city"
                                data-i18n-placeholder="rehome-loc-city-placeholder"
                                placeholder="Montréal" />
                        </div>
                        <div class="col-md-4">
                            <label class="rehome-label" data-i18n="rehome-loc-label-province">Province</label>
                            <select class="rehome-select" name="province">
                                <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                                <option value="QC">Québec</option>
                                <option value="ON">Ontario</option>
                                <option value="BC">British Columbia</option>
                                <option value="AB">Alberta</option>
                                <option value="MB">Manitoba</option>
                                <option value="SK">Saskatchewan</option>
                                <option value="NS">Nova Scotia</option>
                                <option value="NB">New Brunswick</option>
                                <option value="NL">Newfoundland</option>
                                <option value="PE">PEI</option>
                                <option value="NT">Northwest Territories</option>
                                <option value="YT">Yukon</option>
                                <option value="NU">Nunavut</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="rehome-label" data-i18n="rehome-loc-label-postal">Postal Code</label>
                            <input type="text" class="rehome-input" name="postalCode"
                                data-i18n-placeholder="rehome-loc-postal-placeholder"
                                placeholder="H1A 0A1" maxlength="7" />
                        </div>
                    </div>

                    <!-- Pickup arrangements -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-loc-label-pickup">Pickup arrangements</label>
                        <div class="option-chips" data-group="pickup">
                            <button type="button" class="option-chip" data-value="home">
                                <span class="chip-dot"></span><span data-i18n="rehome-loc-pickup-home">Home pickup</span>
                            </button>
                            <button type="button" class="option-chip" data-value="neutral">
                                <span class="chip-dot"></span><span data-i18n="rehome-loc-pickup-neutral">Neutral location</span>
                            </button>
                            <button type="button" class="option-chip" data-value="adopter">
                                <span class="chip-dot"></span><span data-i18n="rehome-loc-pickup-adopter">Adopter's place</span>
                            </button>
                        </div>
                        <input type="hidden" name="pickupType" id="pickupType" />
                    </div>

                    <div class="mb-3">
                        <textarea class="rehome-textarea" name="pickupNotes"
                            data-i18n-placeholder="rehome-loc-pickup-placeholder"
                            placeholder="e.g. Can meet at a neutral location, home pickup available on weekends..."></textarea>
                    </div>

                    <!-- Privacy note -->
                    <div class="loc-privacy-note mb-4">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        <span data-i18n="rehome-loc-privacy-note">Only your city and province are shown publicly. Your exact address is never shared.</span>
                    </div>

                    <!-- ── Section 2: Your story ───────────────────── -->
                    <hr class="rw-section-divider">

                    <div class="rw-section-hdr">
                        <span class="rw-section-icon">✍️</span>
                        <div>
                            <p class="rw-section-title">Your pet's story</p>
                            <p class="rw-section-sub">A personal story helps adopters connect and builds trust</p>
                        </div>
                    </div>

                    <div class="rehome-story-body" style="padding:0">
                        <label class="rehome-label" data-i18n="rehome-story-label">Tell us about your pet</label>
                        <textarea class="story-textarea" name="story" id="storyTextarea"
                            data-i18n-placeholder="rehome-story-placeholder"
                            placeholder="Tell us about your pet's personality, favourite things, daily routine, and why you're looking for a new home for them..."></textarea>

                        <div class="story-footer">
                            <span class="story-char-count">
                                <span class="count-num" id="charCount">0</span>
                                &nbsp;<span data-i18n="rehome-story-chars">characters</span>
                            </span>
                            <span class="story-min-hint" id="minHint" data-i18n="rehome-story-min">Minimum 80 characters</span>
                        </div>

                        <!-- Writing prompts -->
                        <div class="story-prompts">
                            <p class="story-prompts-title" data-i18n="rehome-story-prompts-title">Need inspiration?</p>
                            <ul class="story-prompts-list">
                                <li data-i18n="rehome-story-prompt1">What does a typical day look like for your pet?</li>
                                <li data-i18n="rehome-story-prompt2">What are their favourite toys, games, or activities?</li>
                                <li data-i18n="rehome-story-prompt3">How do they behave around strangers or new environments?</li>
                                <li data-i18n="rehome-story-prompt4">What do you love most about them?</li>
                            </ul>
                        </div>
                    </div>

                    <div class="rehome-divider"></div>

                    <div class="rehome-nav-btns">
                        <a href="/Rehome/Character" class="rehome-btn-back">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                            <span data-i18n="rehome-btn-back">Back</span>
                        </a>
                        <button type="submit" class="rehome-btn-continue">
                            <span data-i18n="rehome-btn-continue">Save &amp; Continue →</span>
                        </button>
                    </div>

                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    // Pickup option chips
    document.querySelectorAll('.option-chips').forEach(function (group) {
        const hiddenInput = document.getElementById('pickupType');
        group.querySelectorAll('.option-chip').forEach(function (chip) {
            chip.addEventListener('click', function () {
                group.querySelectorAll('.option-chip').forEach(c => c.classList.remove('selected'));
                chip.classList.add('selected');
                if (hiddenInput) hiddenInput.value = chip.getAttribute('data-value');
            });
        });
    });

    // Story character counter
    const textarea = document.getElementById('storyTextarea');
    const countEl  = document.getElementById('charCount');
    const hintEl   = document.getElementById('minHint');
    function updateCount() {
        const len = textarea.value.length;
        countEl.textContent = len;
        hintEl.classList.toggle('met', len >= 80);
    }
    textarea.addEventListener('input', updateCount);
    updateCount();
})();
</script>
}
