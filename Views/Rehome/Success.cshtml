@{
    ViewData["Title"] = "Listing Submitted";
}

<div class="rehome-page">
    <div class="rehome-container">

        <div class="success-card">

            <!-- Icon -->
            <div class="success-icon-wrap">
                <div class="success-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                        <polyline points="20 6 9 17 4 12"/>
                    </svg>
                </div>
            </div>

            <!-- Heading -->
            <p class="success-eyebrow" data-i18n="rehome-success-eyebrow">LISTING SUBMITTED</p>
            <h1 class="success-title" data-i18n="rehome-success-title">Thank you!</h1>
            <p class="success-subtitle" data-i18n="rehome-success-subtitle">Your listing has been submitted for review.</p>

            <!-- Main message -->
            <div class="success-msg">
                <p data-i18n="rehome-success-msg">
                    Thank you for uploading your pet's information and documents. Our team will review your listing and we'll contact you shortly to let you know if your request has been accepted. We're excited to help find your pet a loving new home.
                </p>
            </div>

            <!-- What happens next -->
            <div class="success-next">
                <p class="success-next-title" data-i18n="rehome-success-next-title">What happens next?</p>
                <div class="success-next-steps">
                    <div class="success-next-step">
                        <div class="success-next-num">1</div>
                        <div class="success-next-body">
                            <strong data-i18n="rehome-success-next1-title">Review (1–2 hrs)</strong>
                            <span data-i18n="rehome-success-next1-desc">Our team checks your listing to ensure it meets our community standards.</span>
                        </div>
                    </div>
                    <div class="success-next-step">
                        <div class="success-next-num">2</div>
                        <div class="success-next-body">
                            <strong data-i18n="rehome-success-next2-title">Goes live</strong>
                            <span data-i18n="rehome-success-next2-desc">Once approved, your listing is visible to potential adopters right away.</span>
                        </div>
                    </div>
                    <div class="success-next-step">
                        <div class="success-next-num">3</div>
                        <div class="success-next-body">
                            <strong data-i18n="rehome-success-next3-title">Adopter matches</strong>
                            <span data-i18n="rehome-success-next3-desc">Interested adopters will send you applications for you to review at your own pace.</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="success-actions">
                <a href="/" class="success-btn-secondary" data-i18n="rehome-success-btn-home">Back to Home</a>
                <a href="/Home/Adopt" class="success-btn-primary" data-i18n="rehome-success-btn-browse">Browse pets →</a>
            </div>

        </div>

    </div>
</div>
