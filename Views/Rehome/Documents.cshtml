@model PawdoptApp.Models.PetListing
@{
    ViewData["Title"] = "Documents";
    var listingId = (int)(ViewData["ListingId"] ?? 0);
    var savedDocs = new List<string>();
    if (!string.IsNullOrEmpty(Model?.DocumentsJson))
    {
        try { savedDocs = System.Text.Json.JsonSerializer.Deserialize<List<string>>(Model.DocumentsJson) ?? new(); }
        catch (System.Text.Json.JsonException) { }
    }
}

<div class="rehome-page">
    <div class="rehome-container">

        <!-- Breadcrumb -->
        <nav class="rehome-breadcrumb" aria-label="breadcrumb">
            <a href="/" data-i18n="nav-home">Home</a>
            <span class="bc-sep">›</span>
            <a href="/Rehome/List" data-i18n="nav-rehome">Rehome</a>
            <span class="bc-sep">›</span>
            <span class="bc-current" data-i18n="rehome-step7">Documents</span>
        </nav>

        <!-- Step progress -->
        <div class="rehome-stepper" role="list">
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label" data-i18n="rehome-step1">Pet info</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label" data-i18n="rehome-step2">Images</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label" data-i18n="rehome-step3">Character</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label" data-i18n="rehome-step4">Key facts</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label" data-i18n="rehome-step5">Location</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg></div>
                <span class="step-label" data-i18n="rehome-step6">Story</span>
            </div>
            <div class="step-item active" role="listitem">
                <div class="step-circle">7</div>
                <span class="step-label" data-i18n="rehome-step7">Documents</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">8</div>
                <span class="step-label" data-i18n="rehome-step8">Confirm</span>
            </div>
        </div>

        <!-- Form card -->
        <div class="rehome-card">
            <div class="rehome-card-header">
                <h1 class="rehome-card-title" data-i18n="rehome-docs-title">Documents &amp; records</h1>
                <p class="rehome-card-subtitle">
                    <span class="step-pill" data-i18n="rehome-docs-step-pill">Step 7 of 8</span>
                    <span data-i18n="rehome-docs-step-desc">Upload any documents you have. All fields are optional.</span>
                </p>
            </div>

            <form method="post" asp-controller="Rehome" asp-action="SaveStep7" asp-route-id="@listingId">
                @Html.AntiForgeryToken()
                <input type="hidden" name="id" value="@listingId" />
                <div class="rehome-docs-body">

                    <!-- Document checklist -->
                    <label class="rehome-label" data-i18n="rehome-docs-label-have">Documents you have</label>
                    <p class="char-traits-hint" data-i18n="rehome-docs-hint">Check all that apply — you can upload files below</p>

                    <div class="docs-checklist">
                        <label class="doc-check-item@(savedDocs.Contains("vaccination") ? " checked" : "")" id="check-vacc">
                            <input type="checkbox" name="docs" value="vaccination" checked="@savedDocs.Contains("vaccination")" />
                            <span class="doc-check-box">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            <span class="doc-check-label" data-i18n="rehome-docs-vacc">Vaccination certificate</span>
                        </label>
                        <label class="doc-check-item@(savedDocs.Contains("sterilization") ? " checked" : "")" id="check-steril">
                            <input type="checkbox" name="docs" value="sterilization" checked="@savedDocs.Contains("sterilization")" />
                            <span class="doc-check-box">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            <span class="doc-check-label" data-i18n="rehome-docs-steril">Sterilization certificate</span>
                        </label>
                        <label class="doc-check-item@(savedDocs.Contains("microchip") ? " checked" : "")" id="check-chip">
                            <input type="checkbox" name="docs" value="microchip" checked="@savedDocs.Contains("microchip")" />
                            <span class="doc-check-box">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            <span class="doc-check-label" data-i18n="rehome-docs-chip">Microchip certificate</span>
                        </label>
                        <label class="doc-check-item@(savedDocs.Contains("vet") ? " checked" : "")" id="check-vet">
                            <input type="checkbox" name="docs" value="vet" checked="@savedDocs.Contains("vet")" />
                            <span class="doc-check-box">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            <span class="doc-check-label" data-i18n="rehome-docs-vet">Vet records / health history</span>
                        </label>
                        <label class="doc-check-item@(savedDocs.Contains("registration") ? " checked" : "")" id="check-reg">
                            <input type="checkbox" name="docs" value="registration" checked="@savedDocs.Contains("registration")" />
                            <span class="doc-check-box">
                                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                            </span>
                            <span class="doc-check-label" data-i18n="rehome-docs-reg">Registration papers</span>
                        </label>
                    </div>

                    <!-- Upload zone -->
                    <label class="rehome-label" data-i18n="rehome-docs-upload-label">Upload files (optional)</label>
                    <div class="upload-zone" id="docUploadZone" role="button" tabindex="0">
                        <input type="file" id="docInput" accept=".pdf,image/*" multiple hidden />
                        <div class="upload-zone-icon">
                            <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="12" y1="18" x2="12" y2="12"/><line x1="9" y1="15" x2="15" y2="15"/>
                            </svg>
                        </div>
                        <p class="upload-zone-title" data-i18n="rehome-docs-drop-title">Drag documents here</p>
                        <p class="upload-zone-sub" data-i18n="rehome-docs-drop-sub">or click to browse</p>
                        <span class="upload-zone-hint" data-i18n="rehome-docs-drop-hint">PDF · JPG · PNG · Max 10 MB each</span>
                    </div>

                    <div class="photo-counter-row" id="docCountRow" style="display:none">
                        <span class="photo-counter" id="docCount">0</span>
                        <span class="photo-counter-label" data-i18n="rehome-docs-file-count">file(s) selected</span>
                    </div>

                    <div class="docs-note mt-3">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
                        <span data-i18n="rehome-docs-note">Documents are only shared with serious applicants after you approve their request.</span>
                    </div>

                    <div class="rehome-divider"></div>

                    <div class="rehome-nav-btns">
                        <a href="/Rehome/Story/@listingId" class="rehome-btn-back">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                            <span data-i18n="rehome-btn-back">Back</span>
                        </a>
                        <button type="submit" class="rehome-btn-continue">
                            <span data-i18n="rehome-btn-continue">Save &amp; Continue →</span>
                        </button>
                    </div>

                </div>
            </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    // Checkboxes
    document.querySelectorAll('.doc-check-item').forEach(function (label) {
        const cb = label.querySelector('input[type="checkbox"]');
        cb.addEventListener('change', function () {
            label.classList.toggle('checked', cb.checked);
        });
        label.addEventListener('click', function (e) {
            if (e.target === cb) return;
            cb.checked = !cb.checked;
            label.classList.toggle('checked', cb.checked);
            e.preventDefault();
        });
    });

    // File upload
    const zone     = document.getElementById('docUploadZone');
    const input    = document.getElementById('docInput');
    const countEl  = document.getElementById('docCount');
    const countRow = document.getElementById('docCountRow');
    let files = [];

    zone.addEventListener('click', () => input.click());
    zone.addEventListener('keydown', e => { if (e.key === 'Enter' || e.key === ' ') input.click(); });
    zone.addEventListener('dragover', e => { e.preventDefault(); zone.classList.add('drag-over'); });
    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'));
    zone.addEventListener('drop', e => { e.preventDefault(); zone.classList.remove('drag-over'); addFiles(e.dataTransfer.files); });
    input.addEventListener('change', () => { addFiles(input.files); input.value = ''; });

    function addFiles(newFiles) {
        Array.from(newFiles).forEach(f => {
            if (f.size <= 10 * 1024 * 1024) files.push(f);
        });
        countEl.textContent = files.length;
        countRow.style.display = files.length > 0 ? 'flex' : 'none';
        zone.classList.toggle('has-photos', files.length > 0);
    }
})();
</script>
}
