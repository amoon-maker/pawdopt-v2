@{
    ViewData["Title"] = "List a Pet";
}

<!-- Teal progress banner -->
<div class="rw-banner">
    <div class="rw-banner-inner">
        <div class="rw-banner-left">
            <span class="rw-banner-step">Step 1 of 5</span>
            <span class="rw-banner-sep">·</span>
            <span class="rw-banner-name">Pet info</span>
        </div>
        <div class="rw-banner-bar"><div class="rw-banner-fill" style="width:20%"></div></div>
    </div>
</div>

<div class="rehome-page">
    <div class="rehome-container">

        <!-- Breadcrumb -->
        <nav class="rehome-breadcrumb" aria-label="breadcrumb">
            <a href="/" data-i18n="nav-home">Home</a>
            <span class="bc-sep">›</span>
            <a href="/Rehome/List" data-i18n="nav-rehome">Rehome</a>
            <span class="bc-sep">›</span>
            <span class="bc-current" data-i18n="rehome-breadcrumb-list">List a pet</span>
        </nav>

        <!-- Step progress -->
        <div class="rehome-stepper" role="list">
            <div class="step-item active" role="listitem">
                <div class="step-circle">1</div>
                <span class="step-label">Pet info</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">2</div>
                <span class="step-label">Photos</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">3</div>
                <span class="step-label">Character</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">4</div>
                <span class="step-label">Location</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">5</div>
                <span class="step-label">Confirm</span>
            </div>
        </div>

        <!-- Form card -->
        <div class="rehome-card">
            <div class="rehome-card-header">
                <h1 class="rehome-card-title" data-i18n="rehome-title">Tell us about your pet</h1>
                <p class="rehome-card-subtitle">
                    <span class="step-pill">Step 1 of 5</span>
                    <span data-i18n="rehome-step-desc">Basic information. Your progress is saved after each step.</span>
                </p>
            </div>

            <form method="post" action="/Rehome/SaveStep1">

                <!-- Row 1: Pet Name | Species | Breed -->
                <div class="row g-3 mb-3">
                    <div class="col-md-5">
                        <label class="rehome-label" data-i18n="rehome-label-name">Pet Name</label>
                        <input type="text" class="rehome-input" name="petName" placeholder="Magie" required />
                    </div>
                    <div class="col-md-4">
                        <label class="rehome-label" data-i18n="rehome-label-species">Species</label>
                        <select class="rehome-select" name="species" required>
                            <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                            <option value="dog" data-i18n="rehome-opt-dog">Dog</option>
                            <option value="cat" data-i18n="rehome-opt-cat">Cat</option>
                        </select>
                    </div>
                    <div class="col-md-3">
                        <label class="rehome-label" data-i18n="rehome-label-breed">Breed</label>
                        <input type="text" class="rehome-input" name="breed" placeholder="Shiba Inu" />
                    </div>
                </div>

                <!-- Row 2: Age | Gender | Size -->
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="rehome-label" data-i18n="rehome-label-age">Age</label>
                        <input type="text" class="rehome-input" name="age" placeholder="14 months" />
                    </div>
                    <div class="col-md-4">
                        <label class="rehome-label" data-i18n="rehome-label-gender">Gender</label>
                        <select class="rehome-select" name="gender" required>
                            <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                            <option value="male" data-i18n="tag-male">Male</option>
                            <option value="female" data-i18n="tag-female">Female</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="rehome-label" data-i18n="rehome-label-size">Size</label>
                        <select class="rehome-select" name="size" required>
                            <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                            <option value="small" data-i18n="tag-small">Small</option>
                            <option value="medium" data-i18n="tag-medium">Medium</option>
                            <option value="large" data-i18n="tag-large">Large</option>
                        </select>
                    </div>
                </div>

                <!-- Row 3: Color | Weight | Microchipped -->
                <div class="row g-3 mb-3">
                    <div class="col-md-4">
                        <label class="rehome-label" data-i18n="rehome-label-color">Color</label>
                        <input type="text" class="rehome-input" name="color" placeholder="Brown / White" />
                    </div>
                    <div class="col-md-4">
                        <label class="rehome-label" data-i18n="rehome-label-weight">Weight (kg)</label>
                        <input type="number" class="rehome-input" name="weight" placeholder="12" min="0" step="0.1" />
                    </div>
                    <div class="col-md-4">
                        <label class="rehome-label" data-i18n="rehome-label-microchip">Microchipped?</label>
                        <select class="rehome-select" name="microchipped">
                            <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                            <option value="yes" data-i18n="rehome-opt-yes">Yes</option>
                            <option value="no" data-i18n="rehome-opt-no">No</option>
                            <option value="unknown" data-i18n="rehome-opt-unknown">Unknown</option>
                        </select>
                    </div>
                </div>

                <!-- Row 4: Reason for rehoming -->
                <div class="mb-0">
                    <label class="rehome-label" data-i18n="rehome-label-reason">Reason for Rehoming</label>
                    <textarea class="rehome-textarea" name="reason" data-i18n-placeholder="rehome-placeholder-reason"
                        placeholder="Moving to a smaller apartment that does not allow pets..." required minlength="20"></textarea>
                </div>

                <div class="rehome-divider"></div>

                <div class="rehome-nav-btns">
                    <a href="/Rehome/List" class="rehome-btn-back">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                        <span data-i18n="rehome-btn-back">Back</span>
                    </a>
                    <button type="submit" class="rehome-btn-continue">
                        <span data-i18n="rehome-btn-continue">Save &amp; Continue →</span>
                    </button>
                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    var form = document.querySelector('form[action="/Rehome/SaveStep1"]');
    var errorBanner = null;

    function showError(msg) {
        if (!errorBanner) {
            errorBanner = document.createElement('div');
            errorBanner.className = 'rw-step-error';
            form.insertBefore(errorBanner, form.firstChild);
        }
        errorBanner.textContent = msg;
        errorBanner.style.display = 'flex';
        errorBanner.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    function hideError() {
        if (errorBanner) errorBanner.style.display = 'none';
    }

    form.setAttribute('novalidate', '');
    form.addEventListener('submit', function (e) {
        var lang = localStorage.getItem('pawdopt-lang') || 'en';
        var fr = lang === 'fr';

        var name = form.querySelector('[name="petName"]').value.trim();
        var species = form.querySelector('[name="species"]').value;
        var gender = form.querySelector('[name="gender"]').value;
        var size = form.querySelector('[name="size"]').value;
        var reason = form.querySelector('[name="reason"]').value.trim();

        if (!name) {
            e.preventDefault();
            showError(fr ? 'Veuillez entrer le nom de votre animal.' : 'Please enter your pet\'s name.');
            return;
        }
        if (!species) {
            e.preventDefault();
            showError(fr ? 'Veuillez sélectionner l\'espèce.' : 'Please select a species.');
            return;
        }
        if (!gender) {
            e.preventDefault();
            showError(fr ? 'Veuillez sélectionner le sexe.' : 'Please select a gender.');
            return;
        }
        if (!size) {
            e.preventDefault();
            showError(fr ? 'Veuillez sélectionner la taille.' : 'Please select a size.');
            return;
        }
        if (reason.length < 20) {
            e.preventDefault();
            showError(fr ? 'Veuillez décrire la raison du rehoming (20 caractères minimum).' : 'Please describe your reason for rehoming (at least 20 characters).');
            return;
        }
        hideError();
    });
})();
</script>
}

