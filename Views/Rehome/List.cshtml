@{
    ViewData["Title"] = "Rehome a Pet";
}

<!-- ── Hero ─────────────────────────────────────────────── -->
<div class="rl-hero">
    <div class="adopt-pg-container">
        <div class="rl-hero-owner">
            <div class="rl-hero-text">
                <p class="rl-hero-eyebrow" data-i18n="rl-eyebrow">🐾 FOR PET OWNERS</p>
                <h1 class="rl-hero-title" data-i18n="rl-title">Give your pet the home they deserve</h1>
                <p class="rl-hero-sub" data-i18n="rl-subtitle">List your pet for free and connect directly with caring adopters in your area, in minutes.</p>
                <div class="rl-hero-actions">
                    <a href="/Rehome/NewListing" class="rl-btn-list" id="startListingBtn" data-i18n="rl-btn-list">Start listing →</a>
                    <a href="#rl-advisors" class="rl-btn-ghost" data-i18n="rl-btn-advisors">Talk to the community ↓</a>
                </div>
            </div>
            <div class="rl-paw-pills" aria-hidden="true">
<span class="rl-paw-pill">🐾 <span data-i18n="rl-paw2">Verified adopters</span></span>
                <span class="rl-paw-pill">🐾 <span data-i18n="rl-paw3">You stay in control</span></span>
                <span class="rl-paw-pill">🐾 <span data-i18n="rl-paw4">Safe &amp; private</span></span>
            </div>
        </div>
    </div>
</div>

<!-- ── How it works ──────────────────────────────────────── -->
<section class="rl-how">
    <div class="adopt-pg-container">
        <div class="rl-sec-head">
            <h2 class="rl-sec-title" data-i18n="rl-how-title">How rehoming works</h2>
            <p class="rl-sec-sub" data-i18n="rl-how-sub">Three simple steps to finding your pet a loving new home</p>
        </div>
        <div class="rl-how-paw-strip" aria-hidden="true">🐾 🐾 🐾 🐾 🐾 🐾 🐾 🐾 🐾 🐾</div>
        <div class="rl-how-steps">
            <div class="rl-how-step">
                <div class="rl-how-bubble">📝</div>
                <h3 class="rl-how-step-title" data-i18n="rl-how-s1">Create your listing</h3>
                <p class="rl-how-step-desc" data-i18n="rl-how-s1d">Fill out a short profile about your pet: personality, health, photos, and the kind of home you're hoping for.</p>
            </div>
            <div class="rl-how-arrow-paw" aria-hidden="true">🐾</div>
            <div class="rl-how-step">
                <div class="rl-how-bubble">🤝</div>
                <h3 class="rl-how-step-title" data-i18n="rl-how-s2">Get connected</h3>
                <p class="rl-how-step-desc" data-i18n="rl-how-s2d">Verified adopters near you discover your listing and reach out. You choose who to respond to, and you're always in control.</p>
            </div>
            <div class="rl-how-arrow-paw" aria-hidden="true">🐾</div>
            <div class="rl-how-step">
                <div class="rl-how-bubble">🏠</div>
                <h3 class="rl-how-step-title" data-i18n="rl-how-s3">Find the right match</h3>
                <p class="rl-how-step-desc" data-i18n="rl-how-s3d">Meet potential adopters, ask questions, and when it feels right, hand your pet to their new family with confidence.</p>
            </div>
        </div>
    </div>
</section>

<div class="rl-wave-sep rl-wave-sep-surface-main" aria-hidden="true">
    <svg viewBox="0 0 1440 52" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path class="rl-wave-path" d="M0,0 C240,44 480,44 720,22 C960,0 1200,0 1440,30 L1440,52 L0,52 Z"></path>
    </svg>
</div>

<!-- ── Community Rehomers ─────────────────────────────────── -->
<section class="rl-advisors" id="rl-advisors">
    <div class="adopt-pg-container">
        <div class="rl-sec-head">
            <h2 class="rl-sec-title" data-i18n="rl-adv-title">Talk to someone who's been there</h2>
            <p class="rl-sec-sub" data-i18n="rl-adv-sub">Connect with Pawdopt members who've already rehomed a pet. They know what it feels like, and they're happy to share their experience.</p>
        </div>
        <div class="rl-adv-grid">

            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#1D8FA3,#176d7e)">SM</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Sophie M.</h3>
                        <div class="rl-adv-badges">
                            <span class="rl-adv-verified">✓ Verified</span>
                            <span class="rl-adv-stars" aria-label="5 stars">★★★★★</span>
                        </div>
                        <p class="rl-adv-role" data-i18n="rl-adv-r1">🐕 Rehomed a Golden Retriever</p>
                        <p class="rl-adv-location">📍 Montréal, QC</p>
                        <p class="rl-adv-desc" data-i18n="rl-adv-d1">"Be honest about your pet's energy level. It saves time and finds the right match faster."</p>
                    </div>
                    <div class="rl-adv-footer">
                        <span class="rl-adv-stat">⏱ <span data-i18n="rl-adv-when1">6 months ago</span></span>
                        <a href="/Rehome/Advisor/sophie-martin" class="rl-adv-btn" data-i18n="rl-adv-btn">Read their story →</a>
                    </div>
                </div>
            </div>

            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#2d7dd2,#1a5fa8)">MT</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Marc T.</h3>
                        <div class="rl-adv-badges">
                            <span class="rl-adv-verified">✓ Verified</span>
                            <span class="rl-adv-stars" aria-label="5 stars">★★★★★</span>
                        </div>
                        <p class="rl-adv-role" data-i18n="rl-adv-r2">🐈 Rehomed two tabby cats</p>
                        <p class="rl-adv-location">📍 Toronto, ON</p>
                        <p class="rl-adv-desc" data-i18n="rl-adv-d2">"Don't rush. A thoughtful listing and good photos make all the difference."</p>
                    </div>
                    <div class="rl-adv-footer">
                        <span class="rl-adv-stat">⏱ <span data-i18n="rl-adv-when2">About a year ago</span></span>
                        <a href="/Rehome/Advisor/marc-tremblay" class="rl-adv-btn" data-i18n="rl-adv-btn">Read their story →</a>
                    </div>
                </div>
            </div>

            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#7c3aed,#5b21b6)">AJ</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Aisha J.</h3>
                        <div class="rl-adv-badges">
                            <span class="rl-adv-verified">✓ Verified</span>
                            <span class="rl-adv-stars" aria-label="5 stars">★★★★★</span>
                        </div>
                        <p class="rl-adv-role" data-i18n="rl-adv-r3">🐕 Rehomed a rescue mix</p>
                        <p class="rl-adv-location">📍 Vancouver, BC</p>
                        <p class="rl-adv-desc" data-i18n="rl-adv-d3">"Take your time with screening. The right family will come, don't settle for the first offer."</p>
                    </div>
                    <div class="rl-adv-footer">
                        <span class="rl-adv-stat">⏱ <span data-i18n="rl-adv-when3">8 months ago</span></span>
