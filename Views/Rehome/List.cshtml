            <div class="rl-adv-card">
                <div class="rl-adv-avatar" style="background:linear-gradient(135deg,#d97706,#b45309)">CR</div>
                <div class="rl-adv-body">
                    <div class="rl-adv-info">
                        <h3 class="rl-adv-name">Carlos R.</h3>
                        <div class="rl-adv-badges">
                            <span class="rl-adv-verified">✓ Verified</span>
