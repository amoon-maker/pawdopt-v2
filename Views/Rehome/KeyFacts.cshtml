@{
    ViewData["Title"] = "Key Facts";
    var listingId = (int)(ViewData["ListingId"] ?? 0);
}

<div class="rehome-page">
    <div class="rehome-container">

        <!-- Breadcrumb -->
        <nav class="rehome-breadcrumb" aria-label="breadcrumb">
            <a href="/" data-i18n="nav-home">Home</a>
            <span class="bc-sep">›</span>
            <a href="/Rehome/List" data-i18n="nav-rehome">Rehome</a>
            <span class="bc-sep">›</span>
            <span class="bc-current" data-i18n="rehome-step4">Key facts</span>
        </nav>

        <!-- Step progress -->
        <div class="rehome-stepper" role="list">
            <div class="step-item completed" role="listitem">
                <div class="step-circle">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="step-label" data-i18n="rehome-step1">Pet info</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="step-label" data-i18n="rehome-step2">Images</span>
            </div>
            <div class="step-item completed" role="listitem">
                <div class="step-circle">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <span class="step-label" data-i18n="rehome-step3">Character</span>
            </div>
            <div class="step-item active" role="listitem">
                <div class="step-circle">4</div>
                <span class="step-label" data-i18n="rehome-step4">Key facts</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">5</div>
                <span class="step-label" data-i18n="rehome-step5">Location</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">6</div>
                <span class="step-label" data-i18n="rehome-step6">Story</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">7</div>
                <span class="step-label" data-i18n="rehome-step7">Documents</span>
            </div>
            <div class="step-item" role="listitem">
                <div class="step-circle">8</div>
                <span class="step-label" data-i18n="rehome-step8">Confirm</span>
            </div>
        </div>

        <!-- Form card -->
        <div class="rehome-card">
            <div class="rehome-card-header">
                <h1 class="rehome-card-title" data-i18n="rehome-kf-title">Key facts about your pet</h1>
                <p class="rehome-card-subtitle">
                    <span class="step-pill" data-i18n="rehome-kf-step-pill">Step 4 of 8</span>
                    <span data-i18n="rehome-kf-step-desc">Health and lifestyle details that adopters need to know.</span>
                </p>
            </div>

            <form method="post" action="/Rehome/SaveStep4">

                <div class="rehome-kf-body">

                    <!-- Row: Vaccinated + Sterilized -->
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="rehome-label" data-i18n="rehome-kf-label-vaccinated">Vaccinated?</label>
                            <select class="rehome-select" name="vaccinated">
                                <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                                <option value="yes" data-i18n="rehome-kf-opt-vaccinated-yes">Yes, fully vaccinated</option>
                                <option value="partial" data-i18n="rehome-kf-opt-vaccinated-partial">Partially vaccinated</option>
                                <option value="no" data-i18n="rehome-kf-opt-vaccinated-no">Not vaccinated</option>
                                <option value="unknown" data-i18n="rehome-kf-opt-vaccinated-unknown">Unknown</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label class="rehome-label" data-i18n="rehome-kf-label-sterilized">Spayed / Neutered?</label>
                            <select class="rehome-select" name="sterilized">
                                <option value="" disabled selected data-i18n="rehome-select-default">Select...</option>
                                <option value="yes" data-i18n="rehome-kf-opt-sterilized-yes">Yes</option>
                                <option value="no" data-i18n="rehome-kf-opt-sterilized-no">No</option>
                                <option value="unknown" data-i18n="rehome-kf-opt-sterilized-unknown">Unknown</option>
                            </select>
                        </div>
                    </div>

                    <!-- Activity level -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-kf-label-activity">Activity level</label>
                        <div class="option-chips" data-group="activity">
                            <button type="button" class="option-chip" data-value="low">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-activity-low">Low</span>
                            </button>
                            <button type="button" class="option-chip" data-value="moderate">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-activity-moderate">Moderate</span>
                            </button>
                            <button type="button" class="option-chip" data-value="high">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-activity-high">High</span>
                            </button>
                        </div>
                        <input type="hidden" name="activityLevel" id="activityLevel" />
                    </div>

                    <!-- Training level -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-kf-label-training">Training level</label>
                        <div class="option-chips" data-group="training">
                            <button type="button" class="option-chip" data-value="none">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-training-none">Not trained</span>
                            </button>
                            <button type="button" class="option-chip" data-value="basic">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-training-basic">Basic commands</span>
                            </button>
                            <button type="button" class="option-chip" data-value="well">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-training-well">Well trained</span>
                            </button>
                        </div>
                        <input type="hidden" name="trainingLevel" id="trainingLevel" />
                    </div>

                    <!-- Ideal home -->
                    <div class="kf-section">
                        <label class="rehome-label" data-i18n="rehome-kf-label-home">Ideal home</label>
                        <div class="option-chips" data-group="home">
                            <button type="button" class="option-chip" data-value="apartment">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-home-apartment">Apartment</span>
                            </button>
                            <button type="button" class="option-chip" data-value="house">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-home-house">House + yard</span>
                            </button>
                            <button type="button" class="option-chip" data-value="any">
                                <span class="chip-dot"></span>
                                <span data-i18n="rehome-kf-home-any">Any home</span>
                            </button>
                        </div>
                        <input type="hidden" name="idealHome" id="idealHome" />
                    </div>

                    <!-- Health notes -->
                    <div class="mb-0">
                        <label class="rehome-label" data-i18n="rehome-kf-label-health">Health &amp; medical notes</label>
                        <textarea class="rehome-textarea" name="healthNotes"
                            data-i18n-placeholder="rehome-kf-health-placeholder"
                            placeholder="Any known conditions, allergies, medications..."></textarea>
                    </div>

                    <div class="rehome-divider"></div>

                    <div class="rehome-nav-btns">
                        <a href="/Rehome/Character/@listingId" class="rehome-btn-back">
                            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                            <span data-i18n="rehome-btn-back">Back</span>
                        </a>
                        <button type="submit" class="rehome-btn-continue">
                            <span data-i18n="rehome-btn-continue">Save &amp; Continue →</span>
                        </button>
                    </div>

                </div>

            </form>
        </div>

    </div>
</div>

@section Scripts {
<script>
(function () {
    document.querySelectorAll('.option-chips').forEach(function (group) {
        const groupName = group.getAttribute('data-group');
        const hiddenInput = document.getElementById(groupName === 'activity' ? 'activityLevel'
                                                   : groupName === 'training' ? 'trainingLevel'
                                                   : 'idealHome');
        group.querySelectorAll('.option-chip').forEach(function (chip) {
            chip.addEventListener('click', function () {
                group.querySelectorAll('.option-chip').forEach(c => c.classList.remove('selected'));
                chip.classList.add('selected');
                if (hiddenInput) hiddenInput.value = chip.getAttribute('data-value');
            });
        });
    });
})();
</script>
}
