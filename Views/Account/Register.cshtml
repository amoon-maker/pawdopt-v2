@model PawdoptApp.Models.RegisterViewModel
@{
    ViewData["Title"] = "Create Account";
}

<div class="auth-page-wrap">
    <div class="auth-card auth-card-wide">

        <div class="auth-logo">
            <span>🐾</span>
            <span class="auth-logo-text">Pawdopt</span>
        </div>

        <h1 class="auth-title" data-i18n="auth-reg-title">Create your account</h1>
        <p class="auth-sub" data-i18n="auth-reg-sub">Join Pawdopt and start your adoption journey</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error-box">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Account" asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <input asp-for="UserType" type="hidden" id="userTypeInput" value="@(Model?.UserType ?? "Adopter")" />

            <!-- Role selector -->
            <div class="auth-field">
                <div class="auth-label" data-i18n="auth-role-title">I am a:</div>
                <div class="auth-role-grid">
                    <div class="auth-role-card active" data-role="Adopter" onclick="selectRole('Adopter')">
                        <span class="auth-role-icon">🏠</span>
                        <div class="auth-role-name" data-i18n="auth-role-adopter">Adopter</div>
                        <div class="auth-role-desc" data-i18n="auth-role-adopter-desc">I want to find a pet to adopt</div>
                    </div>
                    <div class="auth-role-card" data-role="Rehomer" onclick="selectRole('Rehomer')">
                        <span class="auth-role-icon">🐾</span>
                        <div class="auth-role-name" data-i18n="auth-role-rehomer">Rehomer</div>
                        <div class="auth-role-desc" data-i18n="auth-role-rehomer-desc">I need to find a new home for my pet</div>
                    </div>
                </div>
            </div>

            <div class="auth-form-2col">
                <div class="auth-field">
                    <label class="auth-label" data-i18n="auth-fullname">Full name</label>
                    <input asp-for="DisplayName" type="text" class="auth-input" placeholder="Jane Doe" autocomplete="name" />
                    <span asp-validation-for="DisplayName" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label class="auth-label" data-i18n="auth-city">City (optional)</label>
                    <input asp-for="City" type="text" class="auth-input" placeholder="Montreal" />
                </div>
            </div>

            <div class="auth-field">
                <label class="auth-label" data-i18n="auth-email">Email address</label>
                <input asp-for="Email" type="email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="auth-field-error"></span>
            </div>

            <div class="auth-form-2col">
                <div class="auth-field">
                    <label class="auth-label" data-i18n="auth-password">Password</label>
                    <div class="auth-input-wrap">
                        <input asp-for="Password" type="password" class="auth-input" placeholder="Min. 6 chars" autocomplete="new-password" id="regPwdInput" />
                        <button type="button" class="auth-eye-btn" onclick="togglePwd('regPwdInput', this)" aria-label="Show password">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                    <span asp-validation-for="Password" class="auth-field-error"></span>
                </div>
                <div class="auth-field">
                    <label class="auth-label" data-i18n="auth-confirm-pwd">Confirm password</label>
                    <div class="auth-input-wrap">
                        <input asp-for="ConfirmPassword" type="password" class="auth-input" placeholder="••••••••" autocomplete="new-password" id="regConfirmInput" />
                        <button type="button" class="auth-eye-btn" onclick="togglePwd('regConfirmInput', this)" aria-label="Show password">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                        </button>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="auth-field-error"></span>
                </div>
            </div>

            <p class="auth-terms-note">
                By creating an account you agree to Pawdopt's
                <button type="button" class="auth-terms-link" data-bs-toggle="modal" data-bs-target="#termsModal">Terms &amp; Conditions</button>.
            </p>

            <button type="submit" class="auth-submit-btn" data-i18n="auth-btn-register">Create account</button>
        </form>

        <div class="auth-switch">
            <span data-i18n="auth-has-account">Already have an account?</span>
            <a asp-controller="Account" asp-action="Login" data-i18n="auth-login-link">Sign in →</a>
        </div>

    </div>
</div>

@section Scripts {
<script>
function selectRole(role) {
    document.getElementById('userTypeInput').value = role;
    document.querySelectorAll('.auth-role-card').forEach(function(card) {
        card.classList.toggle('active', card.dataset.role === role);
    });
}
function togglePwd(inputId, btn) {
    var input = document.getElementById(inputId);
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.style.opacity = input.type === 'text' ? '1' : '0.5';
}
</script>
}
