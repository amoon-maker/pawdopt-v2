@model PawdoptApp.Models.LoginViewModel
@{
    ViewData["Title"] = "Sign In";
    var returnUrl = ViewData["ReturnUrl"] as string ?? "";
}

<div class="auth-page-wrap">
    <div class="auth-card">

        <div class="auth-logo">
            <span>🐾</span>
            <span class="auth-logo-text">Pawdopt</span>
        </div>

        <h1 class="auth-title" data-i18n="auth-login-title">Welcome back</h1>
        <p class="auth-sub" data-i18n="auth-login-sub">Sign in to your Pawdopt account</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div class="auth-error-box">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <form asp-controller="Account" asp-action="Login" method="post">
            <input type="hidden" name="returnUrl" value="@returnUrl" />
            @Html.AntiForgeryToken()

            <div class="auth-field">
                <label class="auth-label" data-i18n="auth-email">Email address</label>
                <input asp-for="Email" type="email" class="auth-input" placeholder="you@example.com" autocomplete="email" />
                <span asp-validation-for="Email" class="auth-field-error"></span>
            </div>

            <div class="auth-field">
                <div class="auth-label-row">
                    <label class="auth-label" data-i18n="auth-password">Password</label>
                    <button type="button" class="auth-forgot-link" data-i18n="auth-forgot" onclick="document.getElementById('forgotMsg').style.display='block'">Forgot password?</button>
                </div>
                <div class="auth-input-wrap">
                    <input asp-for="Password" type="password" class="auth-input" placeholder="••••••••" autocomplete="current-password" id="loginPwdInput" />
                    <button type="button" class="auth-eye-btn" onclick="togglePwd('loginPwdInput', this)" aria-label="Show password">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                    </button>
                </div>
                <span asp-validation-for="Password" class="auth-field-error"></span>
            </div>

            <div id="forgotMsg" class="auth-info-box" style="display:none" data-i18n-html="auth-forgot-msg">
                Password reset is not available in the demo. Please contact <strong>support&#64;pawdopt.ca</strong>.
            </div>

            <div class="auth-remember">
                <label class="auth-check-label">
                    <input asp-for="RememberMe" type="checkbox" class="auth-checkbox" />
                    <span data-i18n="auth-remember">Remember me</span>
                </label>
            </div>

            <button type="submit" class="auth-submit-btn" data-i18n="auth-btn-login">Sign in</button>
        </form>

        <div class="auth-switch">
            <span data-i18n="auth-no-account">Don't have an account?</span>
            <a asp-controller="Account" asp-action="Register" data-i18n="auth-register-link">Register →</a>
        </div>

    </div>
</div>

@section Scripts {
<script>
function togglePwd(inputId, btn) {
    var input = document.getElementById(inputId);
    input.type = input.type === 'password' ? 'text' : 'password';
    btn.style.opacity = input.type === 'text' ? '1' : '0.5';
}
</script>
}
